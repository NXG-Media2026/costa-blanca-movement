---
import { siteConfig } from '../data/site';
import { t } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Locale } from '../data/site';

interface Props {
  locale?: Locale;
  currentPath?: string;
}

const { locale = 'en', currentPath = '/' } = Astro.props;
const { address, phoneDisplay, phone } = siteConfig;
---

<div class="bg-bg-alt border-b border-border hidden md:block">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div class="flex items-center justify-between h-8 text-xs text-text-muted">

      {/* Left: Rating + Location */}
      <div class="flex items-center gap-4">
        <span class="flex items-center gap-1">
          <span class="text-accent">&#9733;</span>
          <span class="font-medium text-text">4.7</span>
          <span>&mdash;</span>
          <a
            href={locale === 'nl' ? '/nl/reviews' : '/reviews'}
            class="hover:text-accent transition-colors"
          >
            23 {t('review.reviews', locale)}
          </a>
        </span>
        <span class="text-border">|</span>
        <span class="flex items-center gap-1">
          <svg class="w-3.5 h-3.5 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          {address.city}, Costa Blanca
        </span>
      </div>

      {/* Right: Phone + Language */}
      <div class="flex items-center gap-4">
        <a
          href={`tel:${phone}`}
          class="flex items-center gap-1 hover:text-accent transition-colors"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          {phoneDisplay}
        </a>
        <span class="text-border">|</span>
        <LanguageSwitcher locale={locale} currentPath={currentPath} />
      </div>
    </div>
  </div>
</div>
