---
import { getCollection } from 'astro:content';
import GuideCard from './GuideCard.astro';
import type { Locale } from '../data/site';
import { t } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

const guides = await getCollection('guides');
const langGuides = guides
  .filter((g) => g.data.lang === locale)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 2);

const basePath = locale === 'nl' ? '/nl/gidsen' : '/guides';
const allGuidesPath = basePath;

if (langGuides.length === 0) return;
---

<section class="py-16 md:py-24 lg:py-32 bg-bg-alt">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div class="text-center mb-12 md:mb-16 js-reveal">
      <div class="w-12 h-1 bg-accent rounded-full mx-auto mb-6"></div>
      <h2 class="font-heading text-3xl md:text-4xl text-text">
        {t('guide.latestGuides', locale)}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 max-w-4xl mx-auto">
      {langGuides.map((guide, i) => (
        <div class="js-reveal" style={`--reveal-delay: ${i * 120}ms`}>
          <GuideCard
            title={guide.data.title}
            slug={guide.data.pageSlug}
            date={guide.data.date}
            category={guide.data.category}
            excerpt={guide.data.excerpt}
            basePath={basePath}
            locale={locale}
          />
        </div>
      ))}
    </div>

    <div class="text-center mt-10 js-reveal" style="--reveal-delay: 300ms">
      <a
        href={allGuidesPath}
        class="inline-flex items-center text-base font-medium text-accent-dark hover:underline underline-offset-2 transition-colors"
      >
        {t('guide.viewAll', locale)}
        <svg class="w-5 h-5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
