---
import { siteConfig } from '../data/site';
import { navigation } from '../data/navigation';
import { t } from '../i18n/utils';
import type { Locale } from '../data/site';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const navItems = navigation[locale];
const year = new Date().getFullYear();
const homePath = locale === 'nl' ? '/nl' : '/';
const { address } = siteConfig;
const fullAddress = `${address.street}, ${address.postalCode} ${address.city}, ${address.province}, ${address.country}`;
---

<footer class="bg-[#2D2A26] text-white/90">
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href={homePath} class="font-heading text-xl text-white hover:text-accent-light transition-colors">
          {siteConfig.name}
        </a>
        <p class="mt-3 text-sm text-white/60 leading-relaxed">
          {siteConfig.tagline}
        </p>
      </div>

      <!-- Treatments -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/40 mb-4">
          {t('nav.treatments', locale)}
        </h3>
        <ul class="space-y-2.5">
          {navItems
            .find((item) => item.href.includes('treat') || item.href.includes('behandel'))
            ?.children?.map((child) => (
              <li>
                <a href={child.href} class="text-sm text-white/70 hover:text-accent-light transition-colors">
                  {child.label}
                </a>
              </li>
            ))}
        </ul>

        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/40 mb-4 mt-8">
          {t('nav.about', locale)}
        </h3>
        <ul class="space-y-2.5">
          <li>
            <a href={locale === 'nl' ? '/nl/over-ons' : '/about'} class="text-sm text-white/70 hover:text-accent-light transition-colors">
              {t('nav.about', locale)}
            </a>
          </li>
          <li>
            <a href={locale === 'nl' ? '/nl/recensies' : '/reviews'} class="text-sm text-white/70 hover:text-accent-light transition-colors">
              {t('nav.reviews', locale)}
            </a>
          </li>
          <li>
            <a href={locale === 'nl' ? '/nl/veelgestelde-vragen' : '/faq'} class="text-sm text-white/70 hover:text-accent-light transition-colors">
              {t('nav.faq', locale)}
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact / NAP -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/40 mb-4">
          {t('nav.contact', locale)}
        </h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 mt-0.5 text-white/40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <span class="text-sm text-white/70">{fullAddress}</span>
          </li>
          <li>
            <a href={`tel:${siteConfig.phone}`} class="flex items-center gap-3 text-sm text-white/70 hover:text-accent-light transition-colors">
              <svg class="w-5 h-5 text-white/40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              {siteConfig.phoneDisplay}
            </a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.email}`} class="flex items-center gap-3 text-sm text-white/70 hover:text-accent-light transition-colors">
              <svg class="w-5 h-5 text-white/40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              {siteConfig.email}
            </a>
          </li>
        </ul>
      </div>

      <!-- Opening hours -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/40 mb-4">
          {t('location.openingHours', locale)}
        </h3>
        <ul class="space-y-2.5">
          {siteConfig.openingHours.map((slot) => (
            <li class="flex justify-between text-sm">
              <span class="text-white/70">{slot.days}</span>
              <span class:list={['font-medium', slot.hours === 'Closed' ? 'text-white/40' : 'text-white/90']}>
                {slot.hours}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 md:px-6 py-5 flex flex-col md:flex-row items-center justify-between gap-3">
      <p class="text-xs text-white/40">
        &copy; {year} {siteConfig.name}. {t('footer.rights', locale)}.
      </p>
      <a
        href={locale === 'nl' ? '/nl/privacy' : '/privacy'}
        class="text-xs text-white/40 hover:text-white/70 transition-colors"
      >
        {t('footer.privacy', locale)}
      </a>
    </div>
  </div>
</footer>
