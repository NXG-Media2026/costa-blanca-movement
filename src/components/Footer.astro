---
import { siteConfig } from '../data/site';
import { navigation } from '../data/navigation';
import { t } from '../i18n/utils';
import type { Locale } from '../data/site';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const navItems = navigation[locale];
const year = new Date().getFullYear();
const homePath = locale === 'nl' ? '/nl' : '/';
const { address } = siteConfig;
const fullAddress = `${address.street}, ${address.postalCode} ${address.city}, ${address.province}, ${address.country}`;
---

<footer class="bg-[#2D2A26] text-white/90">
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href={homePath} class="font-heading text-xl text-white hover:text-accent-light transition-colors">
          {siteConfig.name}
        </a>
        <p class="mt-3 text-sm text-white/60 leading-relaxed">
          {siteConfig.tagline}
        </p>

        {/* Social icons — only render filled profiles */}
        {(siteConfig.socials.instagram || siteConfig.socials.facebook || siteConfig.socials.linkedin || siteConfig.socials.youtube) && (
          <ul class="mt-6 flex items-center gap-3" aria-label="Social media">
            {siteConfig.socials.instagram && (
              <li>
                <a href={siteConfig.socials.instagram} target="_blank" rel="noopener noreferrer me" aria-label="Instagram"
                  class="inline-flex w-9 h-9 items-center justify-center rounded-full bg-white/5 text-white/70 hover:bg-accent hover:text-white transition-colors">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2.1 1.8.2 2.2.4.5.2.9.5 1.3.9.4.4.6.8.9 1.3.2.4.4 1 .4 2.2.1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c-.1 1.2-.2 1.8-.4 2.2-.2.5-.5.9-.9 1.3-.4.4-.8.6-1.3.9-.4.2-1 .4-2.2.4-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2-.1-1.8-.2-2.2-.4-.5-.2-.9-.5-1.3-.9-.4-.4-.6-.8-.9-1.3-.2-.4-.4-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.8c.1-1.2.2-1.8.4-2.2.2-.5.5-.9.9-1.3.4-.4.8-.6 1.3-.9.4-.2 1-.4 2.2-.4C8.4 2.2 8.8 2.2 12 2.2zm0 1.8c-3.1 0-3.5 0-4.7.1-1.1.1-1.7.2-2.1.4-.5.2-.9.5-1.3.9-.3.3-.6.7-.8 1.3-.2.4-.3 1-.4 2.1-.1 1.2-.1 1.6-.1 4.7s0 3.5.1 4.7c.1 1.1.2 1.7.4 2.1.2.5.5.9.9 1.3.3.3.7.6 1.3.8.4.2 1 .3 2.1.4 1.2.1 1.6.1 4.7.1s3.5 0 4.7-.1c1.1-.1 1.7-.2 2.1-.4.5-.2.9-.5 1.3-.9.3-.3.6-.7.8-1.3.2-.4.3-1 .4-2.1.1-1.2.1-1.6.1-4.7s0-3.5-.1-4.7c-.1-1.1-.2-1.7-.4-2.1-.2-.5-.5-.9-.9-1.3-.3-.3-.7-.6-1.3-.8-.4-.2-1-.3-2.1-.4-1.2-.1-1.6-.1-4.7-.1zm0 3.1a4.9 4.9 0 110 9.8 4.9 4.9 0 010-9.8zm0 8.1a3.2 3.2 0 100-6.4 3.2 3.2 0 000 6.4zm6.3-8.3a1.1 1.1 0 11-2.3 0 1.1 1.1 0 012.3 0z"/>
                  </svg>
                </a>
              </li>
            )}
            {siteConfig.socials.facebook && (
              <li>
                <a href={siteConfig.socials.facebook} target="_blank" rel="noopener noreferrer me" aria-label="Facebook"
                  class="inline-flex w-9 h-9 items-center justify-center rounded-full bg-white/5 text-white/70 hover:bg-accent hover:text-white transition-colors">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M22 12.07C22 6.51 17.52 2 12 2S2 6.51 2 12.07c0 5 3.66 9.15 8.44 9.93v-7.02H7.9v-2.91h2.54V9.84c0-2.52 1.49-3.91 3.78-3.91 1.1 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.45 2.91h-2.33V22c4.78-.78 8.43-4.93 8.43-9.93z"/>
                  </svg>
                </a>
              </li>
            )}
            {siteConfig.socials.linkedin && (
              <li>
                <a href={siteConfig.socials.linkedin} target="_blank" rel="noopener noreferrer me" aria-label="LinkedIn"
                  class="inline-flex w-9 h-9 items-center justify-center rounded-full bg-white/5 text-white/70 hover:bg-accent hover:text-white transition-colors">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 11.01-4.12 2.06 2.06 0 01-.01 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
                  </svg>
                </a>
              </li>
            )}
            {siteConfig.socials.youtube && (
              <li>
                <a href={siteConfig.socials.youtube} target="_blank" rel="noopener noreferrer me" aria-label="YouTube"
                  class="inline-flex w-9 h-9 items-center justify-center rounded-full bg-white/5 text-white/70 hover:bg-accent hover:text-white transition-colors">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 00.5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 002.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 002.1-2.1c.5-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.6 15.6V8.4l6.2 3.6-6.2 3.6z"/>
                  </svg>
                </a>
              </li>
            )}
          </ul>
        )}
      </div>

      <!-- Treatments -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/60 mb-4">
          {t('nav.treatments', locale)}
        </h3>
        <ul class="space-y-2.5">
          {navItems
            .find((item) => item.href.includes('treat') || item.href.includes('behandel'))
            ?.children?.map((child) => (
              <li>
                <a href={child.href} class="text-sm text-white/70 hover:text-accent-light transition-colors">
                  {child.label}
                </a>
              </li>
            ))}
        </ul>

        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/60 mb-4 mt-8">
          {t('nav.about', locale)}
        </h3>
        <ul class="space-y-2.5">
          <li>
            <a href={locale === 'nl' ? '/nl/over-ons' : '/about'} class="text-sm text-white/70 hover:text-accent-light transition-colors">
              {t('nav.about', locale)}
            </a>
          </li>
          <li>
            <a href={locale === 'nl' ? '/nl/reviews' : '/reviews'} class="text-sm text-white/70 hover:text-accent-light transition-colors">
              {t('nav.reviews', locale)}
            </a>
          </li>
          <li>
            <a href={locale === 'nl' ? '/nl/faq' : '/faq'} class="text-sm text-white/70 hover:text-accent-light transition-colors">
              {t('nav.faq', locale)}
            </a>
          </li>
          <li>
            <a href={locale === 'nl' ? '/nl/kwaliteit' : '/credentials'} class="text-sm text-white/70 hover:text-accent-light transition-colors">
              {t('nav.credentials', locale)}
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact / NAP -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/60 mb-4">
          {t('nav.contact', locale)}
        </h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 mt-0.5 text-white/40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <span class="text-sm text-white/70">{fullAddress}</span>
          </li>
          <li>
            <a href={`tel:${siteConfig.phone}`} class="flex items-center gap-3 text-sm text-white/70 hover:text-accent-light transition-colors">
              <svg class="w-5 h-5 text-white/40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              {siteConfig.phoneDisplay}
            </a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.email}`} class="flex items-center gap-3 text-sm text-white/70 hover:text-accent-light transition-colors">
              <svg class="w-5 h-5 text-white/40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              {siteConfig.email}
            </a>
          </li>
        </ul>
      </div>

      <!-- Opening hours -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/60 mb-4">
          {t('location.openingHours', locale)}
        </h3>
        <ul class="space-y-2.5">
          {siteConfig.openingHours.map((slot) => (
            <li class="flex justify-between text-sm">
              <span class="text-white/70">{slot.days}</span>
              <span class:list={['font-medium', slot.hours === 'Closed' ? 'text-white/60' : 'text-white/90']}>
                {slot.hours}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 md:px-6 py-5 flex flex-col md:flex-row items-center justify-between gap-3">
      <p class="text-xs text-white/70">
        &copy; {year} {siteConfig.name}. {t('footer.rights', locale)}.
      </p>
      <a
        href={locale === 'nl' ? '/nl/privacy' : '/privacy'}
        class="text-xs text-white/70 hover:text-white transition-colors"
      >
        {t('footer.privacy', locale)}
      </a>
    </div>
  </div>
</footer>
