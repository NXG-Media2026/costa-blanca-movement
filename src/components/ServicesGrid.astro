---
import type { PageType, CTALocation } from '../lib/analytics';
import { trackOnClick } from '../lib/analytics';
import { t } from '../i18n/utils';
import type { Locale } from '../data/site';

interface ServiceItem {
  title: string;
  slug: string;
  excerpt: string;
  icon?: string;
  image?: string;
  imageAlt?: string;
}

interface Props {
  title: string;
  services: ServiceItem[];
  basePath: string;
  locale?: Locale;
  pageType?: PageType;
  pageSlug?: string;
}

const {
  title,
  services,
  basePath,
  locale = 'en',
  pageType = 'homepage',
  pageSlug = '/',
} = Astro.props;

const featured = services[0];
const rest = services.slice(1);
const allTreatmentsPath = locale === 'nl' ? '/nl/behandelingen' : '/treatments';
---

<section class="py-16 md:py-24 lg:py-32 bg-bg">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div class="text-center mb-12 md:mb-16 js-reveal">
      <h2 class="font-heading text-3xl md:text-4xl text-text mb-4">
        {title}
      </h2>
      <p class="text-text-muted max-w-2xl mx-auto">
        {locale === 'nl'
          ? 'Evidence-based behandelingen, afgestemd op jouw klachten en doelen.'
          : 'Evidence-based treatments, tailored to your condition and goals.'}
      </p>
    </div>

    {/* Featured treatment — large split layout */}
    {featured && (
      <a
        href={`${basePath}/${featured.slug}`}
        class:list={[
          'group block bg-white border border-border rounded-card overflow-hidden mb-8',
          'hover:border-accent/30 hover:shadow-xl transition-all duration-300',
          'js-reveal',
        ]}
        onclick={trackOnClick('treatment_cta_click', {
          page_type: pageType,
          page_slug: pageSlug,
          locale,
          cta_location: 'inline' as CTALocation,
        })}
      >
        <div class="grid grid-cols-1 lg:grid-cols-5">
          {/* Image — 60% */}
          {featured.image && (
            <div class="lg:col-span-3 aspect-[16/10] lg:aspect-auto overflow-hidden">
              <img
                src={featured.image}
                alt={featured.imageAlt || featured.title}
                width="800"
                height="500"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
                loading="lazy"
                decoding="async"
              />
            </div>
          )}

          {/* Text — 40% */}
          <div class="lg:col-span-2 p-8 md:p-10 lg:p-12 flex flex-col justify-center">
            <div class="w-10 h-1 bg-accent rounded-full mb-5"></div>
            <h3 class="font-heading text-2xl md:text-3xl text-text mb-4 group-hover:text-accent transition-colors">
              {featured.title}
            </h3>
            <p class="text-text-muted leading-relaxed mb-6">
              {featured.excerpt}
            </p>
            <span class="inline-flex items-center text-sm font-medium text-accent">
              {t('cta.learnMore', locale)}
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </div>
      </a>
    )}

    {/* Remaining treatments — 3-column grid */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {rest.map((service, idx) => (
        <a
          href={`${basePath}/${service.slug}`}
          class:list={[
            'group block bg-white border border-border rounded-card overflow-hidden',
            'hover:border-accent/30 hover:shadow-xl hover:scale-[1.02]',
            'transition-all duration-300 ease-out',
            'js-reveal',
          ]}
          style={`--reveal-delay: ${idx * 100}ms`}
          onclick={trackOnClick('treatment_cta_click', {
            page_type: pageType,
            page_slug: pageSlug,
            locale,
            cta_location: 'inline' as CTALocation,
          })}
        >
          {/* Card image */}
          {service.image && (
            <div class="aspect-[16/10] overflow-hidden">
              <img
                src={service.image}
                alt={service.imageAlt || service.title}
                width="800"
                height="500"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
                loading="lazy"
                decoding="async"
              />
            </div>
          )}

          {/* Card body */}
          <div class="p-6">
            <h3 class="font-heading text-xl text-text mb-3 group-hover:text-accent transition-colors">
              {service.title}
            </h3>
            <p class="text-sm text-text-muted leading-relaxed mb-4">
              {service.excerpt}
            </p>
            <span class="inline-flex items-center text-sm font-medium text-accent">
              {t('cta.learnMore', locale)}
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    {/* View all link */}
    <div class="text-center mt-10 js-reveal">
      <a
        href={allTreatmentsPath}
        class="inline-flex items-center text-base font-medium text-accent hover:text-accent-dark transition-colors"
      >
        {locale === 'nl' ? 'Bekijk alle behandelingen' : 'View all treatments'}
        <svg class="w-5 h-5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
