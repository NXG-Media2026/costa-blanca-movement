---
import type { PageType, CTALocation } from '../lib/analytics';
import { trackOnClick } from '../lib/analytics';
import { t } from '../i18n/utils';
import type { Locale } from '../data/site';

interface ServiceItem {
  title: string;
  slug: string;
  excerpt: string;
  icon?: string;
}

interface Props {
  title: string;
  services: ServiceItem[];
  basePath: string;
  locale?: Locale;
  pageType?: PageType;
  pageSlug?: string;
}

const {
  title,
  services,
  basePath,
  locale = 'en',
  pageType = 'homepage',
  pageSlug = '/',
} = Astro.props;

const icons: Record<string, string> = {
  spine: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-3-3v6m-7.5 3.75a2.25 2.25 0 012.25-2.25h10.5a2.25 2.25 0 012.25 2.25M12 2.25c-2.485 0-4.5 4.03-4.5 9s2.015 9 4.5 9 4.5-4.03 4.5-9-2.015-9-4.5-9z" />',
  massage: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0" />',
  posture: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12" />',
  needle: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />',
};
---

<section class="py-16 md:py-24 lg:py-32 bg-bg">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <h2 class="font-heading text-3xl md:text-4xl text-text text-center mb-12 md:mb-16">
      {title}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {services.map((service) => (
        <a
          href={`${basePath}/${service.slug}`}
          class="group block p-6 md:p-8 bg-white border border-border rounded-card hover:border-accent/30 hover:shadow-lg transition-all duration-300"
          onclick={trackOnClick('treatment_cta_click', {
            page_type: pageType,
            page_slug: pageSlug,
            locale,
            cta_location: 'inline' as CTALocation,
          })}
        >
          {/* Icon */}
          <div class="w-12 h-12 mb-5 flex items-center justify-center rounded-xl bg-accent-light text-accent">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"
              set:html={icons[service.icon || 'spine'] || icons.spine}
            />
          </div>

          <h3 class="font-heading text-xl text-text mb-3 group-hover:text-accent transition-colors">
            {service.title}
          </h3>
          <p class="text-sm text-text-muted leading-relaxed mb-4">
            {service.excerpt}
          </p>
          <span class="inline-flex items-center text-sm font-medium text-accent group-hover:gap-2 transition-all">
            {t('cta.learnMore', locale)}
            <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
