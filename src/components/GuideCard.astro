---
import type { Locale } from '../data/site';

interface Props {
  title: string;
  slug: string;
  date: string;
  category: string;
  excerpt: string;
  basePath: string;
  locale?: Locale;
  compact?: boolean;
}

const { title, slug, date, category, excerpt, basePath, locale = 'en', compact = false } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString(locale === 'nl' ? 'nl-NL' : 'en-GB', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const categoryColors: Record<string, string> = {
  'Treatment': 'bg-accent/10 text-accent',
  'Prevention': 'bg-emerald-50 text-emerald-700',
  'Recovery': 'bg-sky-50 text-sky-700',
  'Patient Guide': 'bg-amber-50 text-amber-700',
};

const colorClass = categoryColors[category] || 'bg-accent/10 text-accent';
---

<a
  href={`${basePath}/${slug}`}
  class="group block p-6 md:p-8 bg-white border border-border rounded-xl hover:border-accent/30 hover:shadow-lg transition-all duration-300"
>
  <div class="flex items-center gap-3 mb-3">
    <span class={`inline-block px-2.5 py-0.5 text-xs font-medium rounded-full ${colorClass}`}>
      {category}
    </span>
    <time datetime={date} class="text-xs text-text-muted">{formattedDate}</time>
  </div>

  <h3 class={`font-heading text-text group-hover:text-accent transition-colors mb-2 ${compact ? 'text-lg' : 'text-xl md:text-2xl'}`}>
    {title}
  </h3>

  {!compact && (
    <p class="text-text-muted leading-relaxed mb-4">{excerpt}</p>
  )}

  <span class="inline-flex items-center text-sm font-medium text-accent">
    {locale === 'nl' ? 'Lees meer' : 'Read more'}
    <svg class="w-4 h-4 ml-1 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </span>
</a>
