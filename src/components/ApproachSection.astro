---
import type { Locale } from '../data/site';

interface ApproachItem {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  items: ApproachItem[];
  locale?: Locale;
}

const { title, items, locale = 'en' } = Astro.props;

const iconPaths: Record<string, string> = {
  evidence: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  multilingual: 'M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802',
  nonsurgical: 'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z',
  personalized: 'M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z',
};
---

<section class="py-16 md:py-24 lg:py-32 bg-bg">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div class="text-center mb-12 md:mb-16 js-reveal">
      <div class="w-12 h-1 bg-accent rounded-full mx-auto mb-6"></div>
      <h2 class="font-heading text-3xl md:text-4xl text-text">
        {title}
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10">
      {items.map((item, idx) => (
        <div
          class="text-center js-reveal"
          style={`--reveal-delay: ${idx * 100}ms`}
        >
          <div class="w-14 h-14 mx-auto mb-5 rounded-full bg-accent-light flex items-center justify-center">
            <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[item.icon] || iconPaths.evidence} />
            </svg>
          </div>
          <h3 class="font-heading text-lg text-text mb-2">{item.title}</h3>
          <p class="text-sm text-text-muted leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
