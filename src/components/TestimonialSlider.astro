---
import { t } from '../i18n/utils';
import type { Locale } from '../data/site';

interface Testimonial {
  name: string;
  text: string;
  rating: number;
  source?: string;
}

interface Props {
  title?: string;
  testimonials: Testimonial[];
  locale?: Locale;
}

const { title, testimonials, locale = 'en' } = Astro.props;
const heading = title ?? t('review.heading', locale);

function renderStars(rating: number): string {
  return '★'.repeat(Math.round(rating)) + '☆'.repeat(5 - Math.round(rating));
}
---

<section class="py-16 md:py-24 lg:py-32 bg-bg-alt">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <h2 class="font-heading text-3xl md:text-4xl text-text text-center mb-12 md:mb-16">
      {heading}
    </h2>

    {/* CSS-only horizontal scroll on mobile, grid on desktop */}
    <div class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory md:grid md:grid-cols-3 md:overflow-visible md:pb-0 -mx-4 px-4 md:mx-0 md:px-0">
      {testimonials.map((item) => (
        <article class="flex-shrink-0 w-[85vw] md:w-auto snap-center bg-white border border-border rounded-card p-6 md:p-8 flex flex-col">
          {/* Stars */}
          <div class="text-accent text-lg tracking-wider mb-4" aria-label={`${item.rating} out of 5 stars`}>
            {renderStars(item.rating)}
          </div>

          {/* Quote */}
          <blockquote class="flex-1 text-text leading-relaxed mb-6">
            <p>"{item.text}"</p>
          </blockquote>

          {/* Attribution */}
          <footer class="flex items-center justify-between pt-4 border-t border-border">
            <cite class="not-italic text-sm font-medium text-text">{item.name}</cite>
            {item.source && (
              <span class="text-xs text-text-muted">{item.source}</span>
            )}
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
