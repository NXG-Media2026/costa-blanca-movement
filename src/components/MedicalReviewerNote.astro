---
import { siteConfig } from '../data/site';
import { t } from '../i18n/utils';
import type { Locale } from '../data/site';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

const reviewer = siteConfig.team.find((m) => m.slug === siteConfig.medicalContentReview.reviewerSlug)
  ?? siteConfig.team[0];

const aboutPath = locale === 'nl' ? '/nl/over-ons' : '/about';
const profileHref = `${aboutPath}#${reviewer.slug}`;

// Pull a short credential line — first credential or first qualification
const credentialShort = reviewer.qualifications[0] ?? '';

const dateLocale = locale === 'nl' ? 'nl-NL' : 'en-GB';
const reviewedDate = siteConfig.medicalContentReview.lastReviewedDate;
const formatted = new Date(reviewedDate).toLocaleDateString(dateLocale, {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<section class="py-8 md:py-10 bg-bg-alt border-t border-border">
  <div class="max-w-3xl mx-auto px-4 md:px-6">
    <div class="flex items-start gap-4">
      <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center shrink-0" aria-hidden="true">
        <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="flex-1">
        <p class="text-sm text-text">
          <span class="text-text-muted">{t('eeat.reviewedBy', locale)} </span>
          <a href={profileHref} class="font-medium text-text hover:text-accent transition-colors">
            {reviewer.name}{credentialShort ? `, ${credentialShort.split('(').pop()?.replace(')', '').trim() || ''}` : ''}
          </a>
        </p>
        <p class="text-xs text-text-muted mt-1">
          {t('eeat.lastReviewed', locale)} <time datetime={reviewedDate}>{formatted}</time>
          <span class="mx-1.5" aria-hidden="true">·</span>
          <a href={profileHref} class="hover:text-accent transition-colors">{t('eeat.viewProfile', locale)} →</a>
        </p>
      </div>
    </div>
  </div>
</section>
