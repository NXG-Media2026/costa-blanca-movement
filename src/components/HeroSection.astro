---
import type { EventName, CTALocation, PageType } from '../lib/analytics';
import { trackOnClick } from '../lib/analytics';
import type { Locale } from '../data/site';

interface Props {
  title: string;
  subtitle: string;
  ctaText: string;
  ctaHref: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  backgroundImage?: string;
  backgroundAlt?: string;
  locale?: Locale;
  pageType?: PageType;
  pageSlug?: string;
}

const {
  title,
  subtitle,
  ctaText,
  ctaHref,
  secondaryCtaText,
  secondaryCtaHref,
  backgroundImage,
  backgroundAlt = '',
  locale = 'en',
  pageType = 'homepage',
  pageSlug = '/',
} = Astro.props;

const trackProps = { page_type: pageType, page_slug: pageSlug, locale, cta_location: 'hero' as CTALocation };
---

<section class="relative overflow-hidden bg-[#2D2A26] text-white min-h-[60vh] md:min-h-[80vh] flex items-center">
  {/* Background image */}
  {backgroundImage ? (
    <div class="absolute inset-0">
      <img
        src={backgroundImage}
        alt={backgroundAlt}
        width="1920"
        height="1280"
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      {/* Left-to-right gradient overlay for text readability */}
      <div class="absolute inset-0 bg-gradient-to-r from-[#2D2A26]/95 via-[#2D2A26]/75 to-[#2D2A26]/30"></div>
      {/* Bottom fade for smooth section transition */}
      <div class="absolute bottom-0 inset-x-0 h-24 bg-gradient-to-t from-[#2D2A26]/50 to-transparent"></div>
    </div>
  ) : (
    <div class="absolute inset-0 bg-gradient-to-br from-[#2D2A26] via-[#3a3530] to-[#2D2A26]"></div>
  )}

  {/* Subtle warm accent glow */}
  <div class="absolute top-1/3 right-1/4 w-[600px] h-[600px] rounded-full bg-accent/8 blur-[120px] pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 md:px-6 py-24 md:py-32 lg:py-40 w-full">
    <div class="max-w-2xl js-reveal">
      {/* Subtle accent line above title */}
      <div class="w-12 h-1 bg-accent rounded-full mb-8"></div>

      <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl xl:text-7xl leading-[1.1] mb-6">
        {title}
      </h1>
      <p class="text-lg md:text-xl text-white/80 leading-relaxed mb-10 max-w-xl">
        {subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center px-8 py-4 text-base font-medium bg-accent hover:bg-accent-dark text-white transition-all duration-300 rounded-button shadow-lg shadow-accent/25 hover:shadow-xl hover:shadow-accent/30"
          onclick={trackOnClick('appointment_click', trackProps)}
        >
          {ctaText}
          <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        {secondaryCtaText && secondaryCtaHref && (
          <a
            href={secondaryCtaHref}
            class="inline-flex items-center justify-center px-8 py-4 text-base font-medium border border-white/30 hover:border-white/60 hover:bg-white/10 text-white transition-all duration-300 rounded-button"
            onclick={trackOnClick('phone_click', trackProps)}
          >
            <svg class="mr-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            {secondaryCtaText}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
