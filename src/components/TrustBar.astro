---
interface TrustItem {
  value: string;
  label: string;
}

interface Props {
  items: TrustItem[];
}

const { items } = Astro.props;
---

<section class="bg-bg border-b border-border" aria-label="Trust indicators">
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-6 md:py-8">
    <ul class="flex flex-wrap justify-center gap-6 md:gap-12 lg:gap-16">
      {items.map((item) => (
        <li class="flex items-center gap-3 text-center">
          <span class="text-2xl md:text-3xl font-heading text-accent">{item.value}</span>
          <span class="text-sm text-text-muted leading-tight">{item.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
