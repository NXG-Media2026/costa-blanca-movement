---
import { siteConfig } from '../data/site';
import { t } from '../i18n/utils';
import type { Locale } from '../data/site';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const { address, openingHours, serviceAreas, googleMapsUrl } = siteConfig;

const serviceAreaItems = serviceAreas.filter(a => a.type === 'service-area');
---

<section class="py-16 md:py-24 lg:py-32 bg-bg-alt">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

      {/* Map / Location visual */}
      <div class="js-reveal">
        <div class="relative aspect-[4/3] rounded-image overflow-hidden shadow-lg bg-border">
          {siteConfig.googleMapsEmbed ? (
            <iframe
              src={siteConfig.googleMapsEmbed}
              width="100%"
              height="100%"
              style="border:0"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`${siteConfig.name} location on Google Maps`}
              class="absolute inset-0 w-full h-full"
            ></iframe>
          ) : (
            <div class="absolute inset-0 bg-gradient-to-br from-accent/10 via-bg-alt to-accent/5 flex flex-col items-center justify-center p-8 text-center">
              <svg class="w-16 h-16 text-accent/30 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              <p class="font-heading text-xl text-text mb-2">{address.city}, {address.province}</p>
              <p class="text-sm text-text-muted mb-4">{address.street}, {address.postalCode}</p>
              <a
                href={googleMapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center text-sm font-medium text-accent hover:text-accent-dark transition-colors"
              >
                {locale === 'nl' ? 'Bekijk op Google Maps' : 'View on Google Maps'}
                <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
              </a>
            </div>
          )}
        </div>
      </div>

      {/* Location info */}
      <div class="js-reveal" style="--reveal-delay: 150ms">
        <div class="w-12 h-1 bg-accent rounded-full mb-6"></div>
        <h2 class="font-heading text-3xl md:text-4xl text-text mb-4">
          {locale === 'nl'
            ? `Bezoek ons in ${address.city}`
            : `Visit Us in ${address.city}`}
        </h2>
        <p class="text-lg text-text-muted leading-relaxed mb-8">
          {locale === 'nl'
            ? `Ons centraal gelegen kliniek in ${address.city} is makkelijk bereikbaar vanuit de hele zuidelijke Costa Blanca.`
            : `Our centrally located clinic in ${address.city} is easily accessible from across the southern Costa Blanca region.`}
        </p>

        {/* Opening hours compact */}
        <div class="mb-8">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-text-muted mb-3">
            {t('location.openingHours', locale)}
          </h3>
          <div class="space-y-1.5">
            {openingHours.map((slot) => (
              <div class="flex justify-between text-sm max-w-xs">
                <span class="text-text-muted">{slot.days}</span>
                <span class:list={['font-medium', slot.hours === 'Closed' ? 'text-text-muted' : 'text-text']}>
                  {slot.hours}
                </span>
              </div>
            ))}
          </div>
        </div>

        {/* Service areas */}
        {serviceAreaItems.length > 0 && (
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-text-muted mb-3">
              {locale === 'nl' ? 'Ook bereikbaar vanuit' : 'We also serve'}
            </h3>
            <div class="flex flex-wrap gap-2">
              {serviceAreaItems.map((area) => (
                <a
                  href={locale === 'nl' ? `/nl/locaties/${area.slug}` : `/locations/${area.slug}`}
                  class="inline-flex items-center px-3 py-1.5 text-sm bg-white border border-border rounded-button text-text-muted hover:text-accent hover:border-accent/30 transition-colors"
                >
                  {area.name}
                  {area.distanceFromClinic && (
                    <span class="ml-1.5 text-xs text-text-muted/60">({area.distanceFromClinic})</span>
                  )}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
