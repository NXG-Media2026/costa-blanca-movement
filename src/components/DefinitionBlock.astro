---
interface Props {
  term: string;
  definition: string;
  image?: string;
  imageAlt?: string;
}

const { term, definition, image, imageAlt = '' } = Astro.props;
---

<section class="py-16 md:py-24 lg:py-32 bg-bg-alt">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    {image ? (
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16 items-center">
        {/* Text — 60% */}
        <div class="lg:col-span-3 js-reveal">
          <div class="w-12 h-1 bg-accent rounded-full mb-6"></div>
          <h2 class="font-heading text-3xl md:text-4xl text-text mb-6">
            {term}
          </h2>
          <p class="text-lg text-text-muted leading-relaxed">
            {definition}
          </p>
        </div>

        {/* Image — 40% */}
        <div class="lg:col-span-2 js-reveal" style="--reveal-delay: 150ms">
          <img
            src={image}
            alt={imageAlt}
            width="1200"
            height="782"
            class="w-full rounded-image object-cover aspect-[4/3] shadow-lg"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    ) : (
      <div class="max-w-3xl js-reveal">
        <h2 class="font-heading text-3xl md:text-4xl text-text mb-6">
          {term}
        </h2>
        <p class="text-lg text-text-muted leading-relaxed">
          {definition}
        </p>
      </div>
    )}
  </div>
</section>
