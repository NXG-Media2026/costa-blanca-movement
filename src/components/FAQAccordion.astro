---
import { t } from '../i18n/utils';
import type { Locale } from '../data/site';
import type { PageType } from '../lib/analytics';
import { trackOnClick } from '../lib/analytics';

interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  title?: string;
  items: FAQItem[];
  locale?: Locale;
  pageType?: PageType;
  pageSlug?: string;
}

const {
  title,
  items,
  locale = 'en',
  pageType = 'homepage',
  pageSlug = '/',
} = Astro.props;

const heading = title ?? t('faq.heading', locale);
---

<section class="py-16 md:py-24 lg:py-32 bg-bg">
  <div class="max-w-3xl mx-auto px-4 md:px-6">
    <h2 class="font-heading text-3xl md:text-4xl text-text text-center mb-12 md:mb-16">
      {heading}
    </h2>

    <div class="space-y-3">
      {items.map((item) => (
        <details
          class="group border border-border rounded-card overflow-hidden"
          onclick={trackOnClick('faq_expand', { page_type: pageType, page_slug: pageSlug, locale })}
        >
          <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none text-text font-medium hover:text-accent transition-colors">
            <span>{item.q}</span>
            <svg
              class="w-5 h-5 shrink-0 text-text-muted transition-transform duration-200 group-open:rotate-45"
              fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </summary>
          <div class="px-6 pb-6 text-text-muted leading-relaxed">
            <p>{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
