---
interface Props {
  image: string;
  quote?: string;
  attribution?: string;
  alt?: string;
}

const {
  image,
  quote,
  attribution,
  alt = 'Clinic atmosphere',
} = Astro.props;
---

<section class="relative overflow-hidden js-reveal" aria-label="Atmosphere">
  {/* Full-width image */}
  <div class="relative h-[40vh] md:h-[50vh] lg:h-[60vh]">
    <img
      src={image}
      alt={alt}
      class="w-full h-full object-cover"
      loading="lazy"
      decoding="async"
    />

    {/* Dark overlay */}
    <div class="absolute inset-0 bg-[#2D2A26]/40"></div>

    {/* Quote overlay — centered */}
    {quote && (
      <div class="absolute inset-0 flex items-center justify-center px-6">
        <blockquote class="max-w-2xl text-center">
          {/* Decorative quote mark */}
          <svg class="w-10 h-10 md:w-12 md:h-12 mx-auto mb-4 text-white/30" viewBox="0 0 24 24" fill="currentColor">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
          <p class="font-heading text-xl md:text-2xl lg:text-3xl text-white leading-relaxed">
            {quote}
          </p>
          {attribution && (
            <cite class="block mt-4 text-sm text-white/60 not-italic">
              — {attribution}
            </cite>
          )}
        </blockquote>
      </div>
    )}
  </div>
</section>
