---
import { navigation } from '../data/navigation';
import { siteConfig } from '../data/site';
import { t } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Locale } from '../data/site';

interface Props {
  locale?: Locale;
  currentPath?: string;
}

const { locale = 'en', currentPath = '/' } = Astro.props;
const navItems = navigation[locale];
const homePath = locale === 'nl' ? '/nl' : '/';

function isActive(href: string): boolean {
  if (href === '/' || href === '/nl') return currentPath === href;
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-bg/95 backdrop-blur-sm border-b border-border">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo -->
      <a href={homePath} class="font-heading text-xl md:text-2xl text-text hover:text-accent transition-colors">
        {siteConfig.name}
      </a>

      <!-- Desktop navigation -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navItems.map((item) => (
          item.children ? (
            <div class="group relative">
              <a
                href={item.href}
                class:list={[
                  'flex items-center gap-1 px-3 py-2 text-sm font-medium transition-colors rounded-button',
                  isActive(item.href) ? 'text-accent' : 'text-text hover:text-accent',
                ]}
              >
                {item.label}
                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              <div class="invisible opacity-0 translate-y-2 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-200 absolute top-full left-0 pt-2 z-50">
                <ul class="bg-white rounded-card shadow-lg border border-border py-2 min-w-[220px]">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class:list={[
                          'block px-4 py-2.5 text-sm transition-colors',
                          currentPath === child.href ? 'text-accent bg-accent-light' : 'text-text hover:text-accent hover:bg-bg-alt',
                        ]}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                'px-3 py-2 text-sm font-medium transition-colors rounded-button',
                isActive(item.href) ? 'text-accent' : 'text-text hover:text-accent',
              ]}
            >
              {item.label}
            </a>
          )
        ))}

        <!-- Language switcher -->
        <div class="ml-2">
          <LanguageSwitcher locale={locale} currentPath={currentPath} />
        </div>

        <!-- CTA -->
        <a
          href={locale === 'nl' ? '/nl/contact' : '/contact'}
          class="ml-3 inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-accent hover:bg-accent-dark transition-colors rounded-button"
        >
          {t('cta.book', locale)}
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="menu-btn"
        class="lg:hidden p-2 -mr-2 text-text hover:text-accent transition-colors"
        aria-label={t('general.menu', locale)}
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg class="menu-icon-open w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="menu-icon-close w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile navigation overlay -->
  <nav
    id="mobile-nav"
    class="hidden lg:hidden fixed inset-0 top-16 z-40 bg-bg overflow-y-auto"
    aria-label="Mobile navigation"
  >
    <div class="px-4 py-6 space-y-1">
      {navItems.map((item) => (
        item.children ? (
          <details class="group">
            <summary class="flex items-center justify-between py-3 text-lg font-medium text-text cursor-pointer list-none">
              <span>{item.label}</span>
              <svg class="w-5 h-5 text-text-muted transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <ul class="pl-4 pb-2 space-y-1">
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'block py-2 text-base transition-colors',
                    isActive(item.href) ? 'text-accent font-medium' : 'text-text-muted hover:text-accent',
                  ]}
                >
                  {t('cta.viewAll', locale)}
                </a>
              </li>
              {item.children.map((child) => (
                <li>
                  <a
                    href={child.href}
                    class:list={[
                      'block py-2 text-base transition-colors',
                      currentPath === child.href ? 'text-accent font-medium' : 'text-text-muted hover:text-accent',
                    ]}
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        ) : (
          <a
            href={item.href}
            class:list={[
              'block py-3 text-lg font-medium transition-colors',
              isActive(item.href) ? 'text-accent' : 'text-text hover:text-accent',
            ]}
          >
            {item.label}
          </a>
        )
      ))}

      <!-- Mobile language switcher -->
      <div class="pt-4 mt-4 border-t border-border flex items-center gap-3">
        <span class="text-sm text-text-muted">{t('general.language', locale)}:</span>
        <LanguageSwitcher locale={locale} currentPath={currentPath} />
      </div>

      <!-- Mobile CTA -->
      <a
        href={locale === 'nl' ? '/nl/contact' : '/contact'}
        class="block w-full mt-4 py-3 text-center text-base font-medium text-white bg-accent hover:bg-accent-dark transition-colors rounded-button"
      >
        {t('cta.book', locale)}
      </a>
    </div>
  </nav>
</header>

<script is:inline>
  (function() {
    var btn = document.getElementById('menu-btn');
    var nav = document.getElementById('mobile-nav');
    if (!btn || !nav) return;
    btn.addEventListener('click', function() {
      var open = nav.classList.contains('hidden');
      nav.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(open));
      btn.querySelector('.menu-icon-open').classList.toggle('hidden');
      btn.querySelector('.menu-icon-close').classList.toggle('hidden');
    });
  })();
</script>
