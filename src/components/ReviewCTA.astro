---
import { t } from '../i18n/utils';
import { trackOnClick } from '../lib/analytics';
import type { Locale } from '../data/site';
import type { PageType } from '../lib/analytics';

interface Props {
  text?: string;
  googleUrl?: string;
  locale?: Locale;
  pageType?: PageType;
  pageSlug?: string;
}

const {
  text,
  googleUrl = '#',
  locale = 'en',
  pageType = 'treatment',
  pageSlug = '/',
} = Astro.props;

const heading = text ?? t('review.cta', locale);
---

<section class="py-12 md:py-16 bg-bg">
  <div class="max-w-3xl mx-auto px-4 md:px-6 text-center">
    <div class="p-8 bg-accent-light rounded-card">
      <h2 class="font-heading text-2xl text-text mb-3">
        {heading}
      </h2>
      <p class="text-text-muted mb-6">
        {locale === 'nl'
          ? 'Je ervaring helpt anderen om de juiste keuze te maken.'
          : 'Your experience helps others make the right choice.'}
      </p>
      <a
        href={googleUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center px-6 py-3 text-sm font-medium text-white bg-accent hover:bg-accent-dark transition-colors rounded-button"
        onclick={trackOnClick('review_cta_click', {
          page_type: pageType,
          page_slug: pageSlug,
          locale,
          cta_location: 'inline',
        })}
      >
        {t('review.leaveReview', locale)}
        <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>
</section>
