---
import BaseLayout from './BaseLayout.astro';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';
import DefinitionBlock from '../components/DefinitionBlock.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import RelatedConditions from '../components/RelatedConditions.astro';
import ReviewCTA from '../components/ReviewCTA.astro';
import CTABand from '../components/CTABand.astro';
import { siteConfig } from '../data/site';
import { t } from '../i18n/utils';
import {
  generateLocalBusiness,
  generateBreadcrumbs,
  generateService,
  generateFAQPage,
} from '../data/schema';
import type { Locale } from '../data/site';

interface Props {
  frontmatter: {
    title: string;
    slug: string;
    lang: 'en' | 'nl';
    translationSlug?: string;
    metaTitle: string;
    metaDescription: string;
    definition: string;
    duration: string;
    price?: string;
    relatedConditions: string[];
    faq: Array<{ q: string; a: string }>;
  };
  conditionTitles: Record<string, string>;
}

const { frontmatter, conditionTitles = {} } = Astro.props;
const locale = frontmatter.lang as Locale;
const isNl = locale === 'nl';

const treatmentsPath = isNl ? '/nl/behandelingen' : '/treatments';
const conditionsPath = isNl ? '/nl/klachten' : '/conditions';
const contactPath = isNl ? '/nl/contact' : '/contact';
const pageUrl = `${treatmentsPath}/${frontmatter.slug}`;

const breadcrumbs = [
  { label: t('breadcrumb.home', locale), href: isNl ? '/nl' : '/' },
  { label: t('breadcrumb.treatments', locale), href: treatmentsPath },
  { label: frontmatter.title },
];

const breadcrumbSchema = breadcrumbs.map((b) => ({
  name: b.label,
  url: b.href ? `${siteConfig.url}${b.href}` : `${siteConfig.url}${pageUrl}`,
}));

const schemas = [
  generateLocalBusiness(),
  generateBreadcrumbs(breadcrumbSchema),
  generateService({
    name: frontmatter.title,
    description: frontmatter.metaDescription,
    url: `${siteConfig.url}${pageUrl}`,
  }),
];

if (frontmatter.faq.length > 0) {
  schemas.push(generateFAQPage(frontmatter.faq));
}

const hreflang = frontmatter.translationSlug
  ? [
      { lang: 'en', href: `${siteConfig.url}/treatments/${isNl ? frontmatter.translationSlug : frontmatter.slug}` },
      { lang: 'nl', href: `${siteConfig.url}/nl/behandelingen/${isNl ? frontmatter.slug : frontmatter.translationSlug}` },
    ]
  : [];

const relatedConditionItems = frontmatter.relatedConditions.map((slug) => ({
  title: conditionTitles[slug] || slug.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()),
  slug,
}));
---

<BaseLayout
  title={frontmatter.metaTitle}
  description={frontmatter.metaDescription}
  canonical={`${siteConfig.url}${pageUrl}`}
  schemas={schemas}
  hreflang={hreflang}
  locale={locale}
>
  <BreadcrumbNav items={breadcrumbs} />

  <article class="py-12 md:py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 md:px-6">
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl text-text mb-8">
        {frontmatter.title}
      </h1>

      {/* Meta: duration + price */}
      <div class="flex flex-wrap gap-4 mb-10 text-sm text-text-muted">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {t('treatment.duration', locale)}: {frontmatter.duration}
        </span>
        {frontmatter.price && (
          <span class="flex items-center gap-2">
            {t('treatment.price', locale)}: {frontmatter.price}
          </span>
        )}
      </div>

      {/* Definition block */}
      <div class="p-6 md:p-8 bg-bg-alt rounded-card mb-12">
        <h2 class="font-heading text-xl md:text-2xl text-text mb-3">
          {t('treatment.whatIs', locale)} {frontmatter.title}?
        </h2>
        <p class="text-text-muted leading-relaxed">{frontmatter.definition}</p>
      </div>

      {/* Markdown content */}
      <div class="prose prose-lg max-w-none
        prose-headings:font-heading prose-headings:text-text prose-headings:font-normal
        prose-p:text-text-muted prose-p:leading-relaxed
        prose-a:text-accent prose-a:no-underline hover:prose-a:underline
        prose-li:text-text-muted
        prose-strong:text-text prose-strong:font-semibold
        mb-12"
      >
        <slot />
      </div>
    </div>
  </article>

  {/* Related conditions */}
  <RelatedConditions
    conditions={relatedConditionItems}
    basePath={conditionsPath}
    locale={locale}
  />

  {/* FAQ */}
  {frontmatter.faq.length > 0 && (
    <FAQAccordion
      items={frontmatter.faq}
      locale={locale}
      pageType="treatment"
      pageSlug={frontmatter.slug}
    />
  )}

  {/* Review CTA */}
  <ReviewCTA
    locale={locale}
    pageType="treatment"
    pageSlug={frontmatter.slug}
  />

  {/* Bottom CTA */}
  <CTABand
    title={isNl ? 'Klaar om een afspraak te maken?' : 'Ready to Book Your Appointment?'}
    subtitle={isNl
      ? 'Neem contact op voor een persoonlijk behandelplan.'
      : 'Get in touch to discuss your personalised treatment plan.'}
    ctaText={t('cta.book', locale)}
    ctaHref={contactPath}
    eventName="appointment_click"
    ctaLocation="treatment_bottom"
    locale={locale}
    pageType="treatment"
    pageSlug={frontmatter.slug}
  />
</BaseLayout>
