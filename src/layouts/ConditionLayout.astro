---
import BaseLayout from './BaseLayout.astro';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import RelatedTreatments from '../components/RelatedTreatments.astro';
import MedicalReviewerNote from '../components/MedicalReviewerNote.astro';
import ReviewCTA from '../components/ReviewCTA.astro';
import CTABand from '../components/CTABand.astro';
import { siteConfig } from '../data/site';
import { t } from '../i18n/utils';
import {
  generateLocalBusiness,
  generateBreadcrumbs,
  generateMedicalCondition,
  generateFAQPage,
} from '../data/schema';
import type { Locale } from '../data/site';

interface Props {
  frontmatter: {
    title: string;
    slug: string;
    lang: 'en' | 'nl';
    translationSlug?: string;
    metaTitle: string;
    metaDescription: string;
    definition: string;
    symptoms: string[];
    causes: string[];
    whenToSeekHelp?: string;
    relatedTreatments: string[];
    faq: Array<{ q: string; a: string }>;
  };
  treatmentTitles: Record<string, string>;
}

const { frontmatter, treatmentTitles = {} } = Astro.props;
const locale = frontmatter.lang as Locale;
const isNl = locale === 'nl';

const conditionsPath = isNl ? '/nl/klachten' : '/conditions';
const treatmentsPath = isNl ? '/nl/behandelingen' : '/treatments';
const contactPath = isNl ? '/nl/contact' : '/contact';
const pageUrl = `${conditionsPath}/${frontmatter.slug}`;

const breadcrumbs = [
  { label: t('breadcrumb.home', locale), href: isNl ? '/nl' : '/' },
  { label: t('breadcrumb.conditions', locale), href: conditionsPath },
  { label: frontmatter.title },
];

const breadcrumbSchema = breadcrumbs.map((b) => ({
  name: b.label,
  url: b.href ? `${siteConfig.url}${b.href}` : `${siteConfig.url}${pageUrl}`,
}));

const schemas = [
  generateLocalBusiness(),
  generateBreadcrumbs(breadcrumbSchema),
  generateMedicalCondition({
    name: frontmatter.title,
    description: frontmatter.metaDescription,
    url: `${siteConfig.url}${pageUrl}`,
    symptoms: frontmatter.symptoms,
    causes: frontmatter.causes,
  }),
];

if (frontmatter.faq.length > 0) {
  schemas.push(generateFAQPage(frontmatter.faq));
}

const hreflang = frontmatter.translationSlug
  ? [
      { lang: 'en', href: `${siteConfig.url}/conditions/${isNl ? frontmatter.translationSlug : frontmatter.slug}` },
      { lang: 'nl', href: `${siteConfig.url}/nl/klachten/${isNl ? frontmatter.slug : frontmatter.translationSlug}` },
    ]
  : [];

const relatedTreatmentItems = frontmatter.relatedTreatments.map((slug) => ({
  title: treatmentTitles[slug] || slug.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()),
  slug,
}));
---

<BaseLayout
  title={frontmatter.metaTitle}
  description={frontmatter.metaDescription}
  canonical={`${siteConfig.url}${pageUrl}`}
  schemas={schemas}
  hreflang={hreflang}
  locale={locale}
>
  <BreadcrumbNav items={breadcrumbs} />

  <article class="py-12 md:py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 md:px-6">
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl text-text mb-8">
        {frontmatter.title}
      </h1>

      {/* Definition block */}
      <div class="p-6 md:p-8 bg-bg-alt rounded-card mb-12">
        <h2 class="font-heading text-xl md:text-2xl text-text mb-3">
          {t('condition.whatIs', locale)} {frontmatter.title}?
        </h2>
        <p class="text-text-muted leading-relaxed">{frontmatter.definition}</p>
      </div>

      {/* Symptoms */}
      {frontmatter.symptoms.length > 0 && (
        <div class="mb-10">
          <h2 class="font-heading text-2xl md:text-3xl text-text mb-5">
            {t('condition.symptoms', locale)}
          </h2>
          <ul class="space-y-3">
            {frontmatter.symptoms.map((symptom) => (
              <li class="flex items-start gap-3 text-text-muted">
                <svg class="w-5 h-5 mt-0.5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126z" />
                </svg>
                <span>{symptom}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {/* Causes */}
      {frontmatter.causes.length > 0 && (
        <div class="mb-10">
          <h2 class="font-heading text-2xl md:text-3xl text-text mb-5">
            {t('condition.causes', locale)}
          </h2>
          <ul class="space-y-3">
            {frontmatter.causes.map((cause) => (
              <li class="flex items-start gap-3 text-text-muted">
                <svg class="w-5 h-5 mt-0.5 text-text-muted shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
                <span>{cause}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {/* When to seek help */}
      {frontmatter.whenToSeekHelp && (
        <div class="p-6 md:p-8 bg-accent-light rounded-card mb-12">
          <h2 class="font-heading text-xl md:text-2xl text-text mb-3">
            {t('condition.whenToSeekHelp', locale)}
          </h2>
          <p class="text-text-muted leading-relaxed">{frontmatter.whenToSeekHelp}</p>
        </div>
      )}

      {/* Markdown content */}
      <div class="prose prose-lg max-w-none
        prose-headings:font-heading prose-headings:text-text prose-headings:font-normal
        prose-p:text-text-muted prose-p:leading-relaxed
        prose-a:text-accent prose-a:no-underline hover:prose-a:underline
        prose-li:text-text-muted
        prose-strong:text-text prose-strong:font-semibold
        mb-12"
      >
        <slot />
      </div>
    </div>
  </article>

  {/* Related treatments */}
  <RelatedTreatments
    treatments={relatedTreatmentItems}
    basePath={treatmentsPath}
    locale={locale}
  />

  {/* Medical reviewer note — E-E-A-T for YMYL health content */}
  <MedicalReviewerNote locale={locale} />

  {/* FAQ */}
  {frontmatter.faq.length > 0 && (
    <FAQAccordion
      items={frontmatter.faq}
      locale={locale}
      pageType="condition"
      pageSlug={frontmatter.slug}
    />
  )}

  {/* Review CTA */}
  <ReviewCTA
    locale={locale}
    pageType="condition"
    pageSlug={frontmatter.slug}
  />

  {/* Bottom CTA */}
  <CTABand
    title={isNl ? 'Last van deze klachten?' : 'Struggling With These Symptoms?'}
    subtitle={isNl
      ? 'Boek een assessment en ontdek hoe wij kunnen helpen.'
      : 'Book an assessment and discover how we can help you move better.'}
    ctaText={t('cta.book', locale)}
    ctaHref={contactPath}
    eventName="appointment_click"
    ctaLocation="treatment_bottom"
    locale={locale}
    pageType="condition"
    pageSlug={frontmatter.slug}
  />
</BaseLayout>
