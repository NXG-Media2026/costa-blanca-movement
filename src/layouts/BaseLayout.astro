---
import '@fontsource-variable/inter';
import '@fontsource/dm-serif-display';
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../data/site';
import type { Locale } from '../data/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  hreflang?: Array<{ lang: string; href: string }>;
  noindex?: boolean;
  schemas?: string[];
  locale?: Locale;
}

const {
  title,
  description,
  canonical = `${siteConfig.url}${Astro.url.pathname}`,
  ogImage,
  ogType,
  hreflang,
  noindex = false,
  schemas = [],
  locale = 'en',
} = Astro.props;
---

<!DOCTYPE html>
<html lang={locale} class="scroll-smooth">
<head>
  <SEOHead
    title={title}
    description={description}
    canonical={canonical}
    ogImage={ogImage}
    ogType={ogType}
    hreflang={hreflang}
    noindex={noindex}
    schemas={schemas}
  />

  <!-- Analytics — works without GA4, silent no-op -->
  <script is:inline>
    window.trackEvent=function(n,p){if(location.hostname==='localhost'||location.hostname==='127.0.0.1'){console.log('[Analytics]',n,p);return;}if(typeof gtag==='function'){gtag('event',n,p);}};
  </script>

  {siteConfig.ga4MeasurementId && (
    <Fragment set:html={`<script async src="https://www.googletagmanager.com/gtag/js?id=${siteConfig.ga4MeasurementId}"></script><script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','${siteConfig.ga4MeasurementId}');</script>`} />
  )}
</head>
<body class="bg-bg text-text min-h-screen flex flex-col">
  <!-- Skip to content -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-button focus:text-sm"
  >
    Skip to content
  </a>

  <Header locale={locale} currentPath={Astro.url.pathname} />

  <main id="main-content" class="flex-1">
    <slot />
  </main>

  <Footer locale={locale} />
</body>
</html>
