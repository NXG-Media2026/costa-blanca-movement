---
import '@fontsource-variable/inter';
import '@fontsource/dm-serif-display';
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import { siteConfig } from '../data/site';
import type { Locale } from '../data/site';
import type { PageType } from '../lib/analytics';
import { getTrackingScript, getGA4Script } from '../lib/analytics';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  hreflang?: Array<{ lang: string; href: string }>;
  noindex?: boolean;
  schemas?: string[];
  locale?: Locale;
}

const {
  title,
  description,
  canonical = `${siteConfig.url}${Astro.url.pathname}`,
  ogImage,
  ogType,
  hreflang,
  noindex = false,
  schemas = [],
  locale = 'en',
} = Astro.props;
---

<!DOCTYPE html>
<html lang={locale} class="scroll-smooth">
<head>
  <SEOHead
    title={title}
    description={description}
    canonical={canonical}
    ogImage={ogImage}
    ogType={ogType}
    hreflang={hreflang}
    noindex={noindex}
    schemas={schemas}
  />

  <!-- Analytics — works without GA4, silent no-op -->
  <script is:inline set:html={getTrackingScript()} />
  {siteConfig.analytics.ga4MeasurementId && (
    <Fragment set:html={getGA4Script(siteConfig.analytics.ga4MeasurementId)} />
  )}
</head>
<body class="bg-bg text-text min-h-screen flex flex-col">
  <!-- Skip to content -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-button focus:text-sm"
  >
    Skip to content
  </a>

  <TopBar locale={locale} currentPath={Astro.url.pathname} />
  <Header locale={locale} currentPath={Astro.url.pathname} />

  <main id="main-content" class="flex-1">
    <slot />
  </main>

  <!-- Mobile CTA padding to prevent footer overlap -->
  <div class="h-20 md:hidden" aria-hidden="true"></div>

  <Footer locale={locale} />

  <StickyMobileCTA locale={locale} />

  <!-- Scroll reveal — progressive enhancement, no-JS safe -->
  <script is:inline>
  (function(){
    if(!('IntersectionObserver' in window)) {
      document.querySelectorAll('.js-reveal').forEach(function(el){el.classList.add('is-visible')});
      return;
    }
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){e.target.classList.add('is-visible');io.unobserve(e.target)}
      });
    },{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('.js-reveal').forEach(function(el){io.observe(el)});
  })();
  </script>
</body>
</html>
