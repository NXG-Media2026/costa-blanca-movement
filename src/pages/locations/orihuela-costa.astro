---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import CTABand from '../../components/CTABand.astro';
import { siteConfig } from '../../data/site';
import { trackOnClick } from '../../lib/analytics';
import { generateLocalBusiness, generateBreadcrumbs } from '../../data/schema';

const area = siteConfig.serviceAreas.find((a) => a.slug === 'orihuela-costa')!;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Locations', href: '/locations' },
  { label: 'Orihuela Costa' },
];

const schemas = [
  generateLocalBusiness({ name: area.name }),
  generateBreadcrumbs([
    { name: 'Home', url: siteConfig.url },
    { name: 'Locations', url: `${siteConfig.url}/locations` },
    { name: 'Orihuela Costa', url: `${siteConfig.url}/locations/orihuela-costa` },
  ]),
];

const treatments = [
  { name: 'Spinal Decompression', href: '/treatments/spinal-decompression' },
  { name: 'Sports Massage', href: '/treatments/sports-massage' },
  { name: 'Postural Assessment', href: '/treatments/postural-assessment' },
  { name: 'Dry Needling', href: '/treatments/dry-needling' },
];
---

<BaseLayout
  title={`Spine & Mobility Care for Orihuela Costa | ${siteConfig.name}`}
  description="Specialist spine treatments and sports massage for expats in Orihuela Costa. Just 15 minutes from our clinic in Torrevieja. Spinal decompression, sports massage, dry needling."
  canonical={`${siteConfig.url}/locations/orihuela-costa`}
  schemas={schemas}
  hreflang={[
    { lang: 'en', href: `${siteConfig.url}/locations/orihuela-costa` },
    { lang: 'nl', href: `${siteConfig.url}/nl/locaties/orihuela-costa` },
  ]}
  locale="en"
>
  <BreadcrumbNav items={breadcrumbs} />

  <section class="py-16 md:py-24 lg:py-32">
    <div class="max-w-4xl mx-auto px-4 md:px-6">

      <div class="mb-12 md:mb-16">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs font-semibold uppercase tracking-wider text-text-muted bg-bg-alt px-3 py-1 rounded-full">Service Area</span>
          <span class="text-xs text-text-muted/60">·</span>
          <span class="text-sm text-accent font-medium">{area.distanceFromClinic} from our clinic</span>
        </div>
        <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl text-text mb-4">
          Spine &amp; Mobility Care for Orihuela Costa
        </h1>
        <p class="text-lg text-text-muted leading-relaxed">
          Orihuela Costa — from Playa Flamenca and La Zenia to Villamartín and Cabo Roig — is home to one of the largest expat communities on the southern Costa Blanca. If you're dealing with back pain, neck problems, or sports injuries, specialist help is just 15 minutes away at our Torrevieja clinic.
        </p>
      </div>

      <!-- Clinic card -->
      <div class="bg-bg-alt rounded-card border border-border p-6 md:p-8 mb-12">
        <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-8">
          <div class="flex-1">
            <h2 class="font-heading text-xl text-text mb-2">We treat Orihuela Costa patients at our Torrevieja clinic</h2>
            <p class="text-text-muted leading-relaxed mb-1">
              Our clinic in Torrevieja is a quick 15-minute drive from anywhere in Orihuela Costa via the N-332 or CV-945. Free parking nearby.
            </p>
            <p class="text-sm text-text-muted/60">
              {siteConfig.address.street}, {siteConfig.address.postalCode} {siteConfig.address.city}
            </p>
          </div>
          <div class="flex flex-col gap-3 shrink-0">
            <a
              href={`tel:${siteConfig.phone}`}
              class="inline-flex items-center justify-center gap-2 px-5 py-3 text-sm font-medium text-white bg-accent hover:bg-accent-dark transition-colors rounded-button"
              onclick={trackOnClick('phone_click', { page_type: 'location', page_slug: 'orihuela-costa', locale: 'en', cta_location: 'inline' })}
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              {siteConfig.phoneDisplay}
            </a>
            <a
              href={siteConfig.googleMapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 px-5 py-3 text-sm font-medium text-accent border border-accent hover:bg-accent-light transition-colors rounded-button"
              onclick={trackOnClick('route_click', { page_type: 'location', page_slug: 'orihuela-costa', locale: 'en', cta_location: 'inline' })}
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
              </svg>
              Get Directions
            </a>
          </div>
        </div>
      </div>

      <!-- Distance indicator -->
      <div class="bg-bg-alt rounded-card border border-border p-6 mb-12">
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-2 flex-1">
            <div class="w-3 h-3 rounded-full bg-accent shrink-0"></div>
            <div class="h-px flex-1 bg-border"></div>
            <div class="w-3 h-3 rounded-full bg-accent/40 shrink-0"></div>
          </div>
        </div>
        <div class="flex justify-between mt-2">
          <span class="text-xs font-medium text-accent">Torrevieja (clinic)</span>
          <span class="text-xs text-text-muted">Orihuela Costa — {area.distanceFromClinic}</span>
        </div>
      </div>

      <!-- Content -->
      <div class="prose-section space-y-8 mb-12">
        <div>
          <h2 class="font-heading text-xl md:text-2xl text-text mb-3">Why Orihuela Costa Expats Choose Us</h2>
          <div class="space-y-4 text-text-muted leading-relaxed">
            <p>
              The Orihuela Costa area — including Playa Flamenca, La Zenia, Villamartín, Cabo Roig, and Campoamor — has a thriving British, Scandinavian, and Dutch expat community. Active lifestyles built around golf, walking, and swimming keep people moving, but also bring the risk of chronic pain and sports injuries.
            </p>
            <p>
              At our Torrevieja clinic, we offer treatments rarely available in the area, including motorised spinal decompression therapy. Our multilingual team understands the specific needs of expat patients — including international insurance claims.
            </p>
          </div>
        </div>

        <div>
          <h2 class="font-heading text-xl md:text-2xl text-text mb-3">Getting Here from Orihuela Costa</h2>
          <ul class="space-y-2 text-text-muted">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-1 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span><strong class="text-text">By car:</strong> 15 minutes via N-332 north or CV-945 towards Torrevieja</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-1 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span><strong class="text-text">From La Zenia:</strong> Straight up the CV-95, then CV-905 into Torrevieja centre</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-1 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span><strong class="text-text">Parking:</strong> Free street parking near the clinic</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Available treatments -->
      <div>
        <h2 class="font-heading text-xl md:text-2xl text-text mb-6">Treatments Available</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {treatments.map((t) => (
            <a href={t.href} class="flex items-center gap-3 p-4 bg-bg-alt rounded-card border border-border hover:border-accent/30 transition-colors group">
              <svg class="w-5 h-5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span class="text-sm font-medium text-text group-hover:text-accent transition-colors">{t.name}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTABand
    title="Living in Orihuela Costa? We're Just 15 Minutes Away"
    subtitle="Book your appointment at our Torrevieja clinic. Quick access via the N-332 or CV-945."
    ctaText="Book Appointment"
    ctaHref="/contact"
    locale="en"
    pageType="location"
    pageSlug="orihuela-costa"
  />
</BaseLayout>
