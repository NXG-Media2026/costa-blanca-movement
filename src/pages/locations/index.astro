---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import CTABand from '../../components/CTABand.astro';
import { siteConfig } from '../../data/site';
import { generateLocalBusiness, generateBreadcrumbs } from '../../data/schema';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Locations' },
];

const schemas = [
  generateLocalBusiness(),
  generateBreadcrumbs([
    { name: 'Home', url: siteConfig.url },
    { name: 'Locations', url: `${siteConfig.url}/locations` },
  ]),
];

const areas = [
  {
    name: 'Torrevieja',
    slug: 'torrevieja',
    type: 'primary' as const,
    tagline: 'Our clinic home base',
    description: 'Our main clinic in Torrevieja. Full range of treatments including spinal decompression, sports massage, dry needling, and postural assessment.',
    distance: null,
  },
  {
    name: 'Orihuela Costa',
    slug: 'orihuela-costa',
    type: 'service-area' as const,
    tagline: 'Just 15 minutes away',
    description: 'Serving the large international expat community across Orihuela Costa — from Playa Flamenca to Villamartín and Cabo Roig.',
    distance: '15 min drive',
  },
  {
    name: 'Guardamar del Segura',
    slug: 'guardamar-del-segura',
    type: 'service-area' as const,
    tagline: '15 minutes north',
    description: 'Specialist spine and mobility care for Guardamar residents. A short 15-minute drive to our Torrevieja clinic.',
    distance: '15 min drive',
  },
  {
    name: 'Pilar de la Horadada',
    slug: 'pilar-de-la-horadada',
    type: 'service-area' as const,
    tagline: '20 minutes south',
    description: 'Treating patients from Pilar de la Horadada, Torre de la Horadada, and the Mil Palmeras coast. Just 20 minutes to our clinic.',
    distance: '20 min drive',
  },
];
---

<BaseLayout
  title={`Locations | ${siteConfig.name}`}
  description="Visit Costa Blanca Movement Centre in Torrevieja. We also serve patients from Orihuela Costa (15 min), Guardamar del Segura (15 min), and Pilar de la Horadada (20 min)."
  canonical={`${siteConfig.url}/locations`}
  schemas={schemas}
  hreflang={[
    { lang: 'en', href: `${siteConfig.url}/locations` },
    { lang: 'nl', href: `${siteConfig.url}/nl/locaties` },
  ]}
  locale="en"
>
  <BreadcrumbNav items={breadcrumbs} />

  <section class="py-16 md:py-24 lg:py-32">
    <div class="max-w-5xl mx-auto px-4 md:px-6">
      <div class="max-w-3xl mb-12 md:mb-16">
        <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl text-text mb-4">
          Our Location &amp; Service Areas
        </h1>
        <p class="text-lg text-text-muted leading-relaxed">
          Our clinic is based in Torrevieja, on the southern Costa Blanca. We serve patients from across the region — from Orihuela Costa to Guardamar del Segura and Pilar de la Horadada. Specialist spine and mobility care, close to home.
        </p>
      </div>

      <!-- Map placeholder -->
      <div class="aspect-[16/9] md:aspect-[21/9] bg-bg-alt border border-border rounded-image mb-12 md:mb-16 flex items-center justify-center">
        <div class="text-center text-text-muted">
          <svg class="w-12 h-12 mx-auto mb-3 text-text-muted/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          <p class="text-sm">Southern Costa Blanca service area map</p>
          <p class="text-xs text-text-muted/50 mt-1">Torrevieja · Orihuela Costa · Guardamar · Pilar de la Horadada</p>
        </div>
      </div>

      <!-- Location cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {areas.map((area) => (
          <a
            href={`/locations/${area.slug}`}
            class:list={[
              'block p-6 md:p-8 rounded-card border transition-colors group',
              area.type === 'primary'
                ? 'border-accent/30 bg-accent-light/30 hover:border-accent'
                : 'border-border bg-bg-alt hover:border-accent/30',
            ]}
          >
            <div class="flex items-start justify-between mb-3">
              <div>
                <h2 class="font-heading text-xl md:text-2xl text-text group-hover:text-accent transition-colors">
                  {area.name}
                </h2>
                <p class="text-sm text-accent font-medium mt-0.5">{area.tagline}</p>
              </div>
              {area.type === 'primary' ? (
                <span class="text-xs font-semibold uppercase tracking-wider text-accent bg-accent-light px-2.5 py-1 rounded-full shrink-0">
                  Clinic
                </span>
              ) : (
                <span class="text-xs text-text-muted bg-bg px-2.5 py-1 rounded-full shrink-0">
                  {area.distance}
                </span>
              )}
            </div>
            <p class="text-sm text-text-muted leading-relaxed mb-4">
              {area.description}
            </p>
            <span class="inline-flex items-center text-sm font-medium text-accent group-hover:underline">
              {area.type === 'primary' ? 'View clinic details' : `View ${area.name} page`}
              <svg class="ml-1 w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABand
    title="Ready to Visit?"
    subtitle="Book your appointment at our clinic in Torrevieja. Easy to reach from across the southern Costa Blanca."
    ctaText="Book Appointment"
    ctaHref="/contact"
    locale="en"
    pageType="location"
    pageSlug="locations"
  />
</BaseLayout>
