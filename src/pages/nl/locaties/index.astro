---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../../components/BreadcrumbNav.astro';
import CTABand from '../../../components/CTABand.astro';
import { siteConfig } from '../../../data/site';
import { generateLocalBusiness, generateBreadcrumbs } from '../../../data/schema';

const breadcrumbs = [
  { label: 'Home', href: '/nl' },
  { label: 'Locaties' },
];

const schemas = [
  generateLocalBusiness(),
  generateBreadcrumbs([
    { name: 'Home', url: `${siteConfig.url}/nl` },
    { name: 'Locaties', url: `${siteConfig.url}/nl/locaties` },
  ]),
];

const areas = [
  {
    name: 'Torrevieja',
    slug: 'torrevieja',
    type: 'primary' as const,
    tagline: 'Onze kliniek thuisbasis',
    description: 'Onze hoofdkliniek in Torrevieja. Volledig aanbod van behandelingen waaronder wervelkolom decompressie, sportmassage, dry needling en houdingsanalyse.',
    distance: null,
  },
  {
    name: 'Orihuela Costa',
    slug: 'orihuela-costa',
    type: 'service-area' as const,
    tagline: 'Slechts 15 minuten verderop',
    description: 'We bedienen de grote internationale expat-gemeenschap in Orihuela Costa — van Playa Flamenca tot Villamartin en Cabo Roig.',
    distance: '15 min rijden',
  },
  {
    name: 'Guardamar del Segura',
    slug: 'guardamar-del-segura',
    type: 'service-area' as const,
    tagline: '15 minuten ten noorden',
    description: 'Specialistische wervelkolom- en mobiliteitszorg voor inwoners van Guardamar. Een korte rit van 15 minuten naar onze kliniek in Torrevieja.',
    distance: '15 min rijden',
  },
  {
    name: 'Pilar de la Horadada',
    slug: 'pilar-de-la-horadada',
    type: 'service-area' as const,
    tagline: '20 minuten ten zuiden',
    description: 'Voor patienten uit Pilar de la Horadada, Torre de la Horadada en de Mil Palmeras kust. Slechts 20 minuten rijden naar onze kliniek.',
    distance: '20 min rijden',
  },
];
---

<BaseLayout
  title={`Locaties | ${siteConfig.shortName}`}
  description="Onze kliniek is gevestigd in Torrevieja. We bedienen ook Orihuela Costa, Guardamar del Segura en Pilar de la Horadada."
  canonical={`${siteConfig.url}/nl/locaties`}
  schemas={schemas}
  hreflang={[
    { lang: 'en', href: `${siteConfig.url}/locations` },
    { lang: 'nl', href: `${siteConfig.url}/nl/locaties` },
  ]}
  locale="nl"
>
  <BreadcrumbNav items={breadcrumbs} />

  <section class="py-16 md:py-24 lg:py-32">
    <div class="max-w-5xl mx-auto px-4 md:px-6">
      <div class="max-w-3xl mb-12 md:mb-16">
        <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl text-text mb-4">
          Onze Locatie &amp; Werkgebied
        </h1>
        <p class="text-lg text-text-muted leading-relaxed">
          Onze kliniek is gevestigd in Torrevieja, aan de zuidelijke Costa Blanca. We behandelen patienten uit de hele regio — van Orihuela Costa tot Guardamar del Segura en Pilar de la Horadada. Specialistische wervelkolom- en mobiliteitszorg, dichtbij huis.
        </p>
      </div>

      <!-- Map placeholder -->
      <div class="aspect-[16/9] md:aspect-[21/9] bg-bg-alt border border-border rounded-image mb-12 md:mb-16 flex items-center justify-center">
        <div class="text-center text-text-muted">
          <svg class="w-12 h-12 mx-auto mb-3 text-text-muted/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          <p class="text-sm">Werkgebied zuidelijke Costa Blanca</p>
          <p class="text-xs text-text-muted/50 mt-1">Torrevieja · Orihuela Costa · Guardamar · Pilar de la Horadada</p>
        </div>
      </div>

      <!-- Location cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {areas.map((area) => (
          <a
            href={`/nl/locaties/${area.slug}`}
            class:list={[
              'block p-6 md:p-8 rounded-card border transition-colors group',
              area.type === 'primary'
                ? 'border-accent/30 bg-accent-light/30 hover:border-accent'
                : 'border-border bg-bg-alt hover:border-accent/30',
            ]}
          >
            <div class="flex items-start justify-between mb-3">
              <div>
                <h2 class="font-heading text-xl md:text-2xl text-text group-hover:text-accent transition-colors">
                  {area.name}
                </h2>
                <p class="text-sm text-accent font-medium mt-0.5">{area.tagline}</p>
              </div>
              {area.type === 'primary' ? (
                <span class="text-xs font-semibold uppercase tracking-wider text-accent bg-accent-light px-2.5 py-1 rounded-full shrink-0">
                  Kliniek
                </span>
              ) : (
                <span class="text-xs text-text-muted bg-bg px-2.5 py-1 rounded-full shrink-0">
                  {area.distance}
                </span>
              )}
            </div>
            <p class="text-sm text-text-muted leading-relaxed mb-4">
              {area.description}
            </p>
            <span class="inline-flex items-center text-sm font-medium text-accent group-hover:underline">
              {area.type === 'primary' ? 'Bekijk kliniekdetails' : `Bekijk ${area.name} pagina`}
              <svg class="ml-1 w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABand
    title="Klaar voor een Bezoek?"
    subtitle="Maak een afspraak in onze kliniek in Torrevieja. Goed bereikbaar vanuit de hele zuidelijke Costa Blanca."
    ctaText="Afspraak Maken"
    ctaHref="/nl/contact"
    locale="nl"
    pageType="location"
    pageSlug="locaties"
  />
</BaseLayout>
