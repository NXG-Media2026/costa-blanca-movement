---
import { getCollection } from 'astro:content';
import TreatmentLayout from '../../../layouts/TreatmentLayout.astro';

export async function getStaticPaths() {
  const treatments = await getCollection('treatments');
  const conditions = await getCollection('conditions');

  const nlTreatments = treatments.filter((t) => t.data.lang === 'nl');
  const nlConditions = conditions.filter((c) => c.data.lang === 'nl');

  const conditionTitles: Record<string, string> = {};
  nlConditions.forEach((c) => {
    conditionTitles[c.data.pageSlug] = c.data.title;
  });

  return nlTreatments.map((treatment) => ({
    params: { slug: treatment.data.pageSlug },
    props: { treatment, conditionTitles, slug: treatment.data.pageSlug },
  }));
}

const { treatment, conditionTitles, slug } = Astro.props;
const { Content } = await treatment.render();
---

<TreatmentLayout frontmatter={{ ...treatment.data, slug }} conditionTitles={conditionTitles}>
  <Content />
</TreatmentLayout>
