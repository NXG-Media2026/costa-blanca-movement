---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../../components/BreadcrumbNav.astro';
import CTABand from '../../../components/CTABand.astro';
import { siteConfig } from '../../../data/site';
import { generateLocalBusiness, generateBreadcrumbs } from '../../../data/schema';
import { t } from '../../../i18n/utils';

const conditions = await getCollection('conditions');
const nlConditions = conditions
  .filter((c) => c.data.lang === 'nl')
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const breadcrumbs = [
  { label: 'Home', href: '/nl' },
  { label: 'Klachten' },
];

const schemas = [
  generateLocalBusiness(),
  generateBreadcrumbs([
    { name: 'Home', url: siteConfig.url },
    { name: 'Klachten', url: `${siteConfig.url}/nl/klachten` },
  ]),
];
---

<BaseLayout
  title={`Klachten | ${siteConfig.shortName}`}
  description="Wij behandelen lage rugpijn, nekpijn, ischias, hernia en meer. Leer over je klachten en effectieve niet-chirurgische opties."
  canonical={`${siteConfig.url}/nl/klachten`}
  schemas={schemas}
  hreflang={[
    { lang: 'en', href: `${siteConfig.url}/conditions` },
    { lang: 'nl', href: `${siteConfig.url}/nl/klachten` },
  ]}
  locale="nl"
>
  <BreadcrumbNav items={breadcrumbs} />

  <section class="py-16 md:py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <div class="max-w-3xl mb-12 md:mb-16">
        <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl text-text mb-6">
          Klachten Die Wij Behandelen
        </h1>
        <p class="text-lg text-text-muted leading-relaxed">
          Je klachten begrijpen is de eerste stap naar herstel. Leer over de symptomen, oorzaken en effectieve behandelopties voor veelvoorkomende klachten aan het bewegingsapparaat.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        {nlConditions.map((condition) => (
          <a
            href={`/nl/klachten/${condition.data.pageSlug}`}
            class="group block p-6 md:p-8 bg-white border border-border rounded-card hover:border-accent/30 hover:shadow-lg transition-all duration-300"
          >
            <h2 class="font-heading text-xl md:text-2xl text-text mb-3 group-hover:text-accent transition-colors">
              {condition.data.title}
            </h2>
            <p class="text-text-muted leading-relaxed mb-4">
              {condition.data.definition}
            </p>
            <div class="flex items-center justify-between">
              <span class="text-sm text-text-muted">
                {condition.data.symptoms.length} symptomen
              </span>
              <span class="inline-flex items-center text-sm font-medium text-accent">
                {t('cta.learnMore', 'nl')}
                <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABand
    title="Heb Je Last van Deze Klachten?"
    subtitle="Wacht niet tot de pijn erger wordt. Boek een beoordeling en laat ons je helpen de juiste behandeling te vinden."
    ctaText="Boek Beoordeling"
    ctaHref="/nl/contact"
    locale="nl"
    pageType="condition"
    pageSlug="klachten"
  />
</BaseLayout>
