---
import { getCollection } from 'astro:content';
import ConditionLayout from '../../../layouts/ConditionLayout.astro';

export async function getStaticPaths() {
  const conditions = await getCollection('conditions');
  const treatments = await getCollection('treatments');

  const nlConditions = conditions.filter((c) => c.data.lang === 'nl');
  const nlTreatments = treatments.filter((t) => t.data.lang === 'nl');

  const treatmentTitles: Record<string, string> = {};
  nlTreatments.forEach((t) => {
    treatmentTitles[t.data.pageSlug] = t.data.title;
  });

  return nlConditions.map((condition) => ({
    params: { slug: condition.data.pageSlug },
    props: { condition, treatmentTitles, slug: condition.data.pageSlug },
  }));
}

const { condition, treatmentTitles, slug } = Astro.props;
const { Content } = await condition.render();
---

<ConditionLayout frontmatter={{ ...condition.data, slug }} treatmentTitles={treatmentTitles}>
  <Content />
</ConditionLayout>
