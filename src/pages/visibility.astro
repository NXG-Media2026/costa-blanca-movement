---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import reportData from '../data/client-report.json';

const { scores, traffic, events, reviews, actionsCompleted, nextPriorities, lastUpdated, period, topPages, pageVisibility } = reportData;

// Score helpers
function scoreColor(value: number): string {
  if (value >= 80) return 'text-emerald-600';
  if (value >= 50) return 'text-amber-600';
  return 'text-red-600';
}

function scoreBg(value: number): string {
  if (value >= 80) return 'bg-emerald-50 border-emerald-200';
  if (value >= 50) return 'bg-amber-50 border-amber-200';
  return 'bg-red-50 border-red-200';
}

function scoreBarColor(value: number): string {
  if (value >= 80) return 'bg-emerald-500';
  if (value >= 50) return 'bg-amber-500';
  return 'bg-red-500';
}

function trendArrow(current: number, previous: number): string {
  const diff = current - previous;
  if (diff > 0) return `▲ +${diff}`;
  if (diff < 0) return `▼ ${diff}`;
  return '—';
}

function trendColor(current: number, previous: number): string {
  if (current > previous) return 'text-emerald-600';
  if (current < previous) return 'text-red-600';
  return 'text-text-muted';
}

function statusLabel(status: string): string {
  const map: Record<string, string> = {
    strong: 'Strong',
    improving: 'Improving',
    building: 'Building',
    needs_work: 'Needs Work',
  };
  return map[status] || status;
}

function statusDot(status: string): string {
  const map: Record<string, string> = {
    strong: 'bg-emerald-500',
    improving: 'bg-amber-500',
    building: 'bg-blue-500',
    needs_work: 'bg-red-500',
  };
  return map[status] || 'bg-text-muted';
}

function priorityStatusColor(status: string): string {
  const map: Record<string, string> = {
    done: 'bg-emerald-100 text-emerald-700',
    in_progress: 'bg-amber-100 text-amber-700',
    planned: 'bg-blue-100 text-blue-700',
  };
  return map[status] || 'bg-bg-alt text-text-muted';
}

function priorityStatusLabel(status: string): string {
  const map: Record<string, string> = {
    done: 'Done',
    in_progress: 'In Progress',
    planned: 'Planned',
  };
  return map[status] || status;
}

function formatMonth(monthStr: string): string {
  const [year, month] = monthStr.split('-');
  const date = new Date(parseInt(year), parseInt(month) - 1);
  return date.toLocaleDateString('en-GB', { month: 'short', year: '2-digit' });
}

// Traffic chart helpers
const maxTraffic = Math.max(...traffic.organicClicks.map((t: { value: number }) => t.value), 1);

// Score entries
const scoreEntries = [
  { label: 'Overall', ...scores.overall },
  { label: 'Layer 1: Technical', ...scores.layer1_technical },
  { label: 'Layer 2: Citability', ...scores.layer2_citability },
  { label: 'Layer 3: Authority', ...scores.layer3_authority },
];
---

<DashboardLayout
  title={`Visibility Dashboard | ${period}`}
  description="Private visibility performance dashboard."
  lastUpdated={lastUpdated}
>

  <!-- Page title -->
  <div class="mb-8 md:mb-12">
    <h1 class="font-heading text-2xl md:text-3xl text-text mb-2">
      Visibility Report — {period}
    </h1>
    <p class="text-sm text-text-muted">
      Performance overview across technical SEO, content citability, and brand authority.
    </p>
  </div>

  <!-- ========== SCORE CARDS ========== -->
  <section class="mb-10 md:mb-14">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-text-muted/60 mb-4">Visibility Scores</h2>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
      {scoreEntries.map((s) => (
        <div class:list={['rounded-card border p-5 md:p-6', scoreBg(s.value)]}>
          <p class="text-xs font-medium text-text-muted mb-3 truncate">{s.label}</p>
          <p class:list={['text-3xl md:text-4xl font-heading', scoreColor(s.value)]}>
            {s.value}
          </p>
          <!-- Progress bar -->
          <div class="mt-3 h-1.5 bg-black/5 rounded-full overflow-hidden">
            <div
              class:list={['h-full rounded-full transition-all', scoreBarColor(s.value)]}
              style={`width: ${s.value}%`}
            ></div>
          </div>
          <!-- Trend + status -->
          <div class="mt-3 flex items-center justify-between">
            <span class:list={['text-xs font-medium', trendColor(s.value, s.previousValue)]}>
              {trendArrow(s.value, s.previousValue)}
            </span>
            <span class="inline-flex items-center gap-1.5 text-xs text-text-muted">
              <span class:list={['w-1.5 h-1.5 rounded-full', statusDot(s.status)]}></span>
              {statusLabel(s.status)}
            </span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ========== TRAFFIC TREND ========== -->
  <section class="mb-10 md:mb-14">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-text-muted/60 mb-4">Organic Traffic</h2>
    <div class="bg-white rounded-card border border-border p-5 md:p-6">
      <div class="space-y-4">
        {traffic.organicClicks.map((t: { month: string; value: number }, idx: number) => {
          const prev = idx > 0 ? traffic.organicClicks[idx - 1].value : null;
          const pctWidth = Math.max((t.value / maxTraffic) * 100, 2);
          return (
            <div class="flex items-center gap-4">
              <span class="text-xs text-text-muted w-16 shrink-0 text-right">{formatMonth(t.month)}</span>
              <div class="flex-1 h-8 bg-bg-alt rounded overflow-hidden relative">
                <div
                  class="h-full bg-accent/80 rounded transition-all flex items-center justify-end pr-2"
                  style={`width: ${pctWidth}%`}
                >
                  <span class="text-xs font-medium text-white">{t.value}</span>
                </div>
              </div>
              {prev !== null && (
                <span class:list={['text-xs font-medium w-14 text-right shrink-0', t.value > prev ? 'text-emerald-600' : t.value < prev ? 'text-red-600' : 'text-text-muted']}>
                  {t.value > prev ? `▲ ${Math.round(((t.value - prev) / prev) * 100)}%` : t.value < prev ? `▼ ${Math.round(((prev - t.value) / prev) * 100)}%` : '—'}
                </span>
              )}
            </div>
          );
        })}
      </div>
      <p class="mt-4 text-xs text-text-muted/60">Organic clicks from Google Search Console</p>
    </div>
  </section>

  <!-- ========== TOP PAGES ========== -->
  <section class="mb-10 md:mb-14">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-text-muted/60 mb-4">Top Pages</h2>
    <div class="bg-white rounded-card border border-border overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border bg-bg-alt/50">
            <th class="text-left text-xs font-medium text-text-muted px-5 py-3">Page</th>
            <th class="text-right text-xs font-medium text-text-muted px-5 py-3">Clicks</th>
            <th class="text-right text-xs font-medium text-text-muted px-5 py-3 hidden sm:table-cell">Impressions</th>
            <th class="text-right text-xs font-medium text-text-muted px-5 py-3">Trend</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border/60">
          {topPages.map((p: { page: string; title: string; clicks: number; impressions: number; trend: string }) => (
            <tr>
              <td class="px-5 py-3.5">
                <p class="font-medium text-text">{p.title}</p>
                <p class="text-xs text-text-muted/60 mt-0.5">{p.page}</p>
              </td>
              <td class="text-right px-5 py-3.5 font-medium text-text tabular-nums">{p.clicks}</td>
              <td class="text-right px-5 py-3.5 text-text-muted tabular-nums hidden sm:table-cell">{p.impressions.toLocaleString()}</td>
              <td class="text-right px-5 py-3.5">
                {p.trend === 'up' && <span class="text-xs font-medium text-emerald-600">▲ Rising</span>}
                {p.trend === 'stable' && <span class="text-xs font-medium text-text-muted">— Stable</span>}
                {p.trend === 'down' && <span class="text-xs font-medium text-red-600">▼ Falling</span>}
                {p.trend === 'new' && <span class="inline-block text-xs font-medium px-2 py-0.5 rounded-full bg-blue-50 text-blue-700">New</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ========== PAGE VISIBILITY MAP ========== -->
  <section class="mb-10 md:mb-14">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-text-muted/60 mb-4">Page Visibility Map</h2>
    <div class="bg-white rounded-card border border-border overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border bg-bg-alt/50">
            <th class="text-left text-xs font-medium text-text-muted px-5 py-3">Page</th>
            <th class="text-left text-xs font-medium text-text-muted px-5 py-3 hidden sm:table-cell">Target Query</th>
            <th class="text-center text-xs font-medium text-text-muted px-5 py-3">Google</th>
            <th class="text-center text-xs font-medium text-text-muted px-5 py-3">AI</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border/60">
          {pageVisibility.map((p: { page: string; targetQuery: string; googleStatus: string; aiStatus: string }) => (
            <tr>
              <td class="px-5 py-3.5 font-medium text-text">{p.page}</td>
              <td class="px-5 py-3.5 text-text-muted hidden sm:table-cell">
                <code class="text-xs bg-bg-alt px-1.5 py-0.5 rounded">{p.targetQuery}</code>
              </td>
              <td class="px-5 py-3.5 text-center">
                {p.googleStatus === 'ranking' ? (
                  <span class="inline-block text-xs font-medium px-2.5 py-1 rounded-full bg-emerald-50 text-emerald-700">Ranking</span>
                ) : (
                  <span class="inline-block text-xs font-medium px-2.5 py-1 rounded-full bg-bg-alt text-text-muted">Not yet</span>
                )}
              </td>
              <td class="px-5 py-3.5 text-center">
                {p.aiStatus === 'cited' ? (
                  <span class="inline-block text-xs font-medium px-2.5 py-1 rounded-full bg-emerald-50 text-emerald-700">Cited</span>
                ) : (
                  <span class="inline-block text-xs font-medium px-2.5 py-1 rounded-full bg-bg-alt text-text-muted">Not found</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="mt-3 text-xs text-text-muted/60">Google: Search Console ranking data. AI: tested via ChatGPT, Perplexity, Gemini.</p>
  </section>

  <!-- ========== EVENTS + REVIEWS (side by side on desktop) ========== -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8 mb-10 md:mb-14">

    <!-- Lead Intent Summary -->
    <section>
      <h2 class="text-xs font-semibold uppercase tracking-wider text-text-muted/60 mb-4">Lead Intent Summary — {period}</h2>
      <div class="grid grid-cols-2 gap-4">
        {[
          { label: 'Phone Calls', value: events.phone_clicks, prev: events.previousMonth.phone_clicks },
          { label: 'WhatsApp', value: events.whatsapp_clicks, prev: events.previousMonth.whatsapp_clicks },
          { label: 'Form Submits', value: events.form_submits, prev: events.previousMonth.form_submits },
          { label: 'Route Clicks', value: events.route_clicks, prev: events.previousMonth.route_clicks },
        ].map((e) => {
          const diff = e.value - e.prev;
          const diffStr = diff >= 0 ? `+${diff}` : `${diff}`;
          const diffColor = diff > 0 ? 'text-emerald-600' : diff < 0 ? 'text-red-600' : 'text-text-muted';
          const prevMonth = 'Feb';
          return (
            <div class="bg-white rounded-card border border-border p-4 md:p-5">
              <p class="text-2xl md:text-3xl font-heading text-text mb-1">{e.value}</p>
              <p class="text-xs text-text-muted mb-2">{e.label}</p>
              <p class:list={['text-xs font-medium', diffColor]}>
                {diffStr} vs {prevMonth}
              </p>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Review Summary -->
    <section>
      <h2 class="text-xs font-semibold uppercase tracking-wider text-text-muted/60 mb-4">Reviews — {reviews.source}</h2>
      <div class="bg-white rounded-card border border-border p-5 md:p-6">
        <div class="flex items-center gap-6 mb-4">
          <!-- Star + rating -->
          <div class="text-center">
            <div class="flex items-center gap-1 mb-1">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg
                  class:list={['w-5 h-5', i < Math.round(reviews.averageRating) ? 'text-amber-400' : 'text-border']}
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              ))}
            </div>
            <p class="text-3xl font-heading text-text">{reviews.averageRating}<span class="text-sm text-text-muted">/5</span></p>
          </div>
          <!-- Stats -->
          <div class="flex-1 space-y-2">
            <div class="flex justify-between text-sm">
              <span class="text-text-muted">Total reviews</span>
              <span class="font-medium text-text">{reviews.total}</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-text-muted">New this month</span>
              <span class="font-medium text-emerald-600">+{reviews.newThisMonth}</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- ========== ACTIONS + PRIORITIES (side by side on desktop) ========== -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8 mb-10 md:mb-14">

    <!-- Actions Completed -->
    <section>
      <h2 class="text-xs font-semibold uppercase tracking-wider text-text-muted/60 mb-4">Actions Completed</h2>
      <div class="bg-white rounded-card border border-border divide-y divide-border">
        {actionsCompleted.map((item: { date: string; action: string }) => (
          <div class="px-5 py-4 flex gap-4">
            <time class="text-xs text-text-muted/60 w-20 shrink-0 pt-0.5" datetime={item.date}>
              {new Date(item.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' })}
            </time>
            <p class="text-sm text-text">{item.action}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Next Priorities -->
    <section>
      <h2 class="text-xs font-semibold uppercase tracking-wider text-text-muted/60 mb-4">Next Priorities</h2>
      <div class="bg-white rounded-card border border-border divide-y divide-border">
        {nextPriorities.map((item: { priority: string; status: string }) => (
          <div class="px-5 py-4 flex items-start justify-between gap-4">
            <p class="text-sm text-text">{item.priority}</p>
            <span class:list={['text-xs font-medium px-2.5 py-1 rounded-full shrink-0', priorityStatusColor(item.status)]}>
              {priorityStatusLabel(item.status)}
            </span>
          </div>
        ))}
      </div>
    </section>
  </div>

</DashboardLayout>
