---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';
import ReviewCTA from '../components/ReviewCTA.astro';
import CTABand from '../components/CTABand.astro';
import { siteConfig } from '../data/site';
import { generateLocalBusiness, generateBreadcrumbs, generateAggregateRating } from '../data/schema';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Reviews' },
];

const reviews = [
  {
    name: 'David Thompson',
    rating: 5,
    date: '2025-11-15',
    text: 'After years of lower back pain, I finally found real relief with spinal decompression therapy. Dr. Mitchell explained everything clearly and the results after just 4 sessions were remarkable. Highly recommended for anyone in the Torrevieja area.',
    treatment: 'Spinal Decompression',
  },
  {
    name: 'Annemieke de Vries',
    rating: 5,
    date: '2025-10-28',
    text: 'Fantastische kliniek! Laura is een uitstekende sportmasseur. Als Nederlandse expat is het fijn dat ze Nederlands spreekt. Mijn nek- en schouderklachten zijn enorm verbeterd na een reeks behandelingen.',
    treatment: 'Sports Massage',
  },
  {
    name: 'Margaret Wilson',
    rating: 5,
    date: '2025-10-02',
    text: 'I was sceptical about non-surgical treatment for my herniated disc, but the decompression therapy has genuinely changed my life. I can walk, garden, and enjoy retirement again without constant pain.',
    treatment: 'Spinal Decompression',
  },
  {
    name: 'Peter van Dijk',
    rating: 4,
    date: '2025-09-14',
    text: 'Very professional clinic with modern equipment. The postural assessment was thorough and the follow-up exercises really helped. Only reason for 4 stars is the limited Saturday hours, but otherwise excellent.',
    treatment: 'Postural Assessment',
  },
  {
    name: 'Sarah Jenkins',
    rating: 5,
    date: '2025-08-20',
    text: 'I drive from Orihuela Costa every week for my sports massage with Laura. It\'s worth every kilometre. She found tension I didn\'t even know I had. My golf game has improved noticeably since starting treatment.',
    treatment: 'Sports Massage',
  },
  {
    name: 'Jan Bakker',
    rating: 5,
    date: '2025-07-30',
    text: 'Na een verwijzing van een vriend ben ik hier terecht gekomen voor mijn ischias. De combinatie van decompressie en dry needling werkt uitstekend. Het team is professioneel en spreekt perfect Nederlands.',
    treatment: 'Spinal Decompression',
  },
  {
    name: 'Christine Moreau',
    rating: 5,
    date: '2025-07-05',
    text: 'Moved to Guardamar recently and was worried about finding quality physiotherapy. This clinic exceeded expectations. The initial assessment was incredibly thorough — they actually listen and create a real plan.',
    treatment: 'Postural Assessment',
  },
  {
    name: 'Robert Hughes',
    rating: 4,
    date: '2025-06-12',
    text: 'Good clinic with knowledgeable staff. The dry needling helped my chronic neck pain when nothing else did. They were upfront about what to expect and how many sessions I\'d need. No overselling.',
    treatment: 'Dry Needling',
  },
];

const totalReviews = reviews.length;
const averageRating = Math.round((reviews.reduce((sum, r) => sum + r.rating, 0) / totalReviews) * 10) / 10;

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
}

const schemas = [
  generateLocalBusiness(),
  generateBreadcrumbs([
    { name: 'Home', url: siteConfig.url },
    { name: 'Reviews', url: `${siteConfig.url}/reviews` },
  ]),
  generateAggregateRating({
    ratingValue: averageRating,
    reviewCount: totalReviews,
  }),
];
---

<BaseLayout
  title={`Patient Reviews | ${siteConfig.name}`}
  description={`Read ${totalReviews} patient reviews for ${siteConfig.name} in Torrevieja. Rated ${averageRating}/5 for spine treatments, sports massage, and mobility care.`}
  canonical={`${siteConfig.url}/reviews`}
  schemas={schemas}
  hreflang={[
    { lang: 'en', href: `${siteConfig.url}/reviews` },
    { lang: 'nl', href: `${siteConfig.url}/nl/recensies` },
  ]}
  locale="en"
>
  <BreadcrumbNav items={breadcrumbs} />

  <!-- Rating summary -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 md:px-6 text-center">
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl text-text mb-8">
        What Our Patients Say
      </h1>

      <div class="inline-flex flex-col items-center p-8 bg-bg-alt rounded-card border border-border">
        <!-- Stars -->
        <div class="flex items-center gap-1 mb-3">
          {Array.from({ length: 5 }).map((_, i) => (
            <svg
              class:list={[
                'w-7 h-7',
                i < Math.round(averageRating) ? 'text-amber-400' : 'text-border',
              ]}
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
          ))}
        </div>
        <p class="text-4xl font-heading text-text mb-1">{averageRating}<span class="text-lg text-text-muted">/5</span></p>
        <p class="text-sm text-text-muted">Based on {totalReviews} patient reviews</p>
        <a
          href={siteConfig.social.google || '#'}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-accent hover:underline"
        >
          View on Google
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Reviews grid -->
  <section class="pb-16 md:pb-24">
    <div class="max-w-5xl mx-auto px-4 md:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {reviews.map((review) => (
          <blockquote class="bg-bg-alt rounded-card border border-border p-6 md:p-8 flex flex-col">
            <!-- Stars + date -->
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-0.5">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg
                    class:list={[
                      'w-4 h-4',
                      i < review.rating ? 'text-amber-400' : 'text-border',
                    ]}
                    viewBox="0 0 24 24"
                    fill="currentColor"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                ))}
              </div>
              <time class="text-xs text-text-muted/60" datetime={review.date}>
                {formatDate(review.date)}
              </time>
            </div>

            <!-- Review text -->
            <p class="text-text-muted leading-relaxed mb-4 flex-1">
              "{review.text}"
            </p>

            <!-- Author + treatment -->
            <footer class="flex items-center justify-between pt-4 border-t border-border">
              <cite class="not-italic text-sm font-medium text-text">{review.name}</cite>
              <span class="text-xs text-accent bg-accent-light px-2.5 py-1 rounded-full">
                {review.treatment}
              </span>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <ReviewCTA
    locale="en"
    pageType="reviews"
    pageSlug="reviews"
    googleUrl={siteConfig.social.google || '#'}
  />

  <CTABand
    title="Ready to Start Your Recovery?"
    subtitle="Join our patients who've found lasting relief. Book your first appointment today."
    ctaText="Book Appointment"
    ctaHref="/contact"
    locale="en"
    pageType="reviews"
    pageSlug="reviews"
  />
</BaseLayout>
