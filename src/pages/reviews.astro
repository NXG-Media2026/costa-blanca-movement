---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';
import ReviewCTA from '../components/ReviewCTA.astro';
import CTABand from '../components/CTABand.astro';
import { siteConfig } from '../data/site';
import { getReviews, aggregateRating, treatmentLabel, reviewText } from '../data/reviews';
import {
  generateLocalBusiness,
  generateBreadcrumbs,
  generateAggregateRating,
  generateReviewArray,
} from '../data/schema';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Reviews' },
];

const allReviews = getReviews();
const { ratingValue: averageRating, reviewCount: totalReviews } = aggregateRating(allReviews);

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
}

const schemas = [
  generateLocalBusiness(),
  generateBreadcrumbs([
    { name: 'Home', url: siteConfig.url },
    { name: 'Reviews', url: `${siteConfig.url}/reviews` },
  ]),
  generateAggregateRating({
    ratingValue: averageRating,
    reviewCount: totalReviews,
  }),
  ...generateReviewArray(allReviews, 'en'),
];
---

<BaseLayout
  title={`Patient Reviews | ${siteConfig.shortName}`}
  description={`Read ${totalReviews} patient reviews for ${siteConfig.shortName} in Torrevieja. Rated ${averageRating}/5 for spine and mobility care.`}
  canonical={`${siteConfig.url}/reviews`}
  schemas={schemas}
  hreflang={[
    { lang: 'en', href: `${siteConfig.url}/reviews` },
    { lang: 'nl', href: `${siteConfig.url}/nl/reviews` },
  ]}
  locale="en"
>
  <BreadcrumbNav items={breadcrumbs} />

  <!-- Rating summary -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 md:px-6 text-center">
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl text-text mb-8">
        What Our Patients Say
      </h1>

      <div class="inline-flex flex-col items-center p-8 bg-bg-alt rounded-card border border-border">
        <!-- Stars -->
        <div class="flex items-center gap-1 mb-3">
          {Array.from({ length: 5 }).map((_, i) => (
            <svg
              class:list={[
                'w-7 h-7',
                i < Math.round(averageRating) ? 'text-amber-400' : 'text-border',
              ]}
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
          ))}
        </div>
        <p class="text-4xl font-heading text-text mb-1">{averageRating}<span class="text-lg text-text-muted">/5</span></p>
        <p class="text-sm text-text-muted">Based on {totalReviews} patient reviews</p>
        <a
          href={siteConfig.socials.google || '#'}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-accent hover:underline"
        >
          View on Google
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Reviews grid -->
  <section class="pb-16 md:pb-24">
    <div class="max-w-5xl mx-auto px-4 md:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {allReviews.map((review) => (
          <article class="testimonial bg-bg-alt rounded-card border border-border p-6 md:p-8 flex flex-col" aria-label={`Review by ${review.name}`}>
            <!-- Stars + date -->
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-0.5" aria-label={`${review.rating} out of 5 stars`}>
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg
                    class:list={[
                      'w-4 h-4',
                      i < review.rating ? 'text-amber-400' : 'text-border',
                    ]}
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                ))}
              </div>
              <time class="text-xs text-text-muted/60" datetime={review.date}>
                {formatDate(review.date)}
              </time>
            </div>

            <!-- Review text -->
            <blockquote class="text-text-muted leading-relaxed mb-4 flex-1">
              <p>"{reviewText(review, 'en')}"</p>
            </blockquote>

            <!-- Author + treatment -->
            <footer class="flex items-center justify-between pt-4 border-t border-border">
              <cite class="not-italic text-sm font-medium text-text">{review.name}</cite>
              <span class="text-xs text-accent bg-accent-light px-2.5 py-1 rounded-full">
                {treatmentLabel(review.treatmentSlug, 'en')}
              </span>
            </footer>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ReviewCTA
    locale="en"
    pageType="reviews"
    pageSlug="reviews"
    googleUrl={siteConfig.socials.google || '#'}
  />

  <CTABand
    title="Ready to Start Your Recovery?"
    subtitle="Join our patients who've found lasting relief. Book your first appointment today."
    ctaText="Book Appointment"
    ctaHref="/contact"
    locale="en"
    pageType="reviews"
    pageSlug="reviews"
  />
</BaseLayout>
