---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';
import CTABand from '../components/CTABand.astro';
import { siteConfig } from '../data/site';
import { generateLocalBusiness, generateBreadcrumbs, generatePerson } from '../data/schema';
import { t } from '../i18n/utils';

const locale = 'en' as const;
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'About Us' },
];

const schemas = [
  generateLocalBusiness(),
  generateBreadcrumbs([
    { name: 'Home', url: siteConfig.url },
    { name: 'About Us', url: `${siteConfig.url}/about` },
  ]),
  ...siteConfig.team.map((member) => generatePerson(member)),
];
---

<BaseLayout
  title={`About Us | ${siteConfig.shortName}`}
  description="Meet the team — expert chiropractor and sports massage therapist serving the expat community in Torrevieja, Costa Blanca."
  canonical={`${siteConfig.url}/about`}
  schemas={schemas}
  hreflang={[
    { lang: 'en', href: `${siteConfig.url}/about` },
    { lang: 'nl', href: `${siteConfig.url}/nl/over-ons` },
  ]}
  locale="en"
>
  <BreadcrumbNav items={breadcrumbs} />

  <!-- Mission -->
  <section class="py-16 md:py-24 lg:py-32">
    <div class="max-w-4xl mx-auto px-4 md:px-6">
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl text-text mb-6">
        About {siteConfig.name}
      </h1>
      <div class="space-y-5 text-lg text-text-muted leading-relaxed">
        <p>
          We opened our doors in Torrevieja with a simple mission: provide the expat community on the Costa Blanca with the same quality of specialist spine and mobility care they'd expect back home — in English, Dutch, or Spanish.
        </p>
        <p>
          Too many people put up with chronic pain, limited movement, or recurring injuries because they can't find a practitioner who speaks their language and understands their needs. We're here to change that.
        </p>
        <p>
          Our approach is hands-on, evidence-based, and focused on long-term results — not quick fixes. Every treatment plan is built around your specific condition, lifestyle, and goals.
        </p>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-16 md:py-24 bg-bg-alt">
    <div class="max-w-5xl mx-auto px-4 md:px-6">
      <h2 class="font-heading text-2xl md:text-3xl text-text text-center mb-12 md:mb-16">
        Meet the Team
      </h2>

      <div class="space-y-12 lg:space-y-16">
        {siteConfig.team.map((member) => (
          <article id={member.slug} class="bg-bg rounded-card border border-border overflow-hidden scroll-mt-24">
            <div class="grid grid-cols-1 md:grid-cols-3">
              {/* Photo placeholder — initials avatar */}
              <div class="md:col-span-1 aspect-square md:aspect-auto bg-gradient-to-br from-accent-light to-bg-alt flex items-center justify-center min-h-[240px]">
                <span class="text-6xl md:text-7xl font-heading text-accent/60" aria-hidden="true">
                  {member.name.split(' ').filter(Boolean).map(w => w[0]).join('').slice(0, 2)}
                </span>
              </div>

              <div class="md:col-span-2 p-6 md:p-8 lg:p-10">
                <h3 class="font-heading text-2xl md:text-3xl text-text mb-1">
                  {member.name}
                </h3>
                <p class="text-accent font-medium text-sm mb-5">
                  {member.role}
                </p>

                <p class="text-text-muted leading-relaxed mb-8">
                  {member.description ?? member.bio}
                </p>

                {/* Education */}
                {member.education && member.education.length > 0 && (
                  <div class="mb-6">
                    <h4 class="text-xs font-semibold uppercase tracking-wider text-text-muted/60 mb-3">
                      {t('about.education', locale)}
                    </h4>
                    <ul class="space-y-2">
                      {member.education.map((e) => (
                        <li class="text-sm text-text-muted">
                          <span class="font-medium text-text">{e.degree}</span>
                          {' — '}
                          {e.institution}
                          {e.year && <span class="text-text-muted/60"> · {e.year}</span>}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                {/* Certifications */}
                {member.credentials && member.credentials.length > 0 && (
                  <div class="mb-6">
                    <h4 class="text-xs font-semibold uppercase tracking-wider text-text-muted/60 mb-3">
                      {t('about.credentials', locale)}
                    </h4>
                    <ul class="space-y-2">
                      {member.credentials.map((c) => (
                        <li class="flex items-start gap-2 text-sm text-text-muted">
                          <svg class="w-4 h-4 mt-0.5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                          </svg>
                          <span>
                            <span class="font-medium text-text">{c.name}</span>
                            <span class="text-text-muted/80"> — {c.issuer}</span>
                            {c.year && <span class="text-text-muted/60"> · {c.year}</span>}
                          </span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                {/* Languages */}
                {member.languages && member.languages.length > 0 && (
                  <div class="mb-6">
                    <h4 class="text-xs font-semibold uppercase tracking-wider text-text-muted/60 mb-3">
                      {t('about.languages', locale)}
                    </h4>
                    <ul class="flex flex-wrap gap-2">
                      {member.languages.map((lang) => (
                        <li class="inline-flex items-center px-3 py-1 text-xs font-medium rounded-full bg-bg-alt text-text border border-border">
                          {lang}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                {/* Memberships */}
                {member.memberships && member.memberships.length > 0 && (
                  <div class="mb-6">
                    <h4 class="text-xs font-semibold uppercase tracking-wider text-text-muted/60 mb-3">
                      {t('about.memberships', locale)}
                    </h4>
                    <ul class="space-y-1.5">
                      {member.memberships.map((m) => (
                        <li class="text-sm text-text-muted flex items-start gap-2">
                          <span class="w-1 h-1 rounded-full bg-accent/40 shrink-0 mt-2"></span>
                          <span>{m}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                {/* Publications */}
                {member.publications && member.publications.length > 0 && (
                  <div>
                    <h4 class="text-xs font-semibold uppercase tracking-wider text-text-muted/60 mb-3">
                      {t('about.publications', locale)}
                    </h4>
                    <ul class="space-y-1.5">
                      {member.publications.map((p) => (
                        <li class="text-sm text-text-muted italic">{p}</li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 md:px-6">
      <h2 class="font-heading text-2xl md:text-3xl text-text text-center mb-12">
        Why Choose Us
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Multilingual Care', desc: 'We speak English, Dutch, and Spanish — no language barriers between you and your recovery.' },
          { title: 'Evidence-Based', desc: 'Every treatment we offer is backed by clinical research and proven results.' },
          { title: 'Specialist Equipment', desc: 'Including motorised spinal decompression — one of few clinics on the Costa Blanca to offer this.' },
          { title: 'No Referral Needed', desc: 'Book directly. No GP visit required, no waiting lists.' },
          { title: 'International Insurance', desc: 'We work with most international health insurance providers and provide detailed invoices.' },
          { title: 'Personalised Plans', desc: 'No one-size-fits-all. Your treatment is tailored to your condition, goals, and lifestyle.' },
        ].map((item) => (
          <div class="p-6 bg-bg-alt rounded-card">
            <h3 class="font-heading text-lg text-text mb-2">{item.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABand
    title="Ready to Move Better?"
    subtitle="Book your initial assessment and let's build a plan that works for you."
    ctaText="Book Appointment"
    ctaHref="/contact"
    locale="en"
    pageType="about"
    pageSlug="about"
  />
</BaseLayout>
