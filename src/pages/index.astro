---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import TrustBar from '../components/TrustBar.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import ApproachSection from '../components/ApproachSection.astro';
import AtmosphereSection from '../components/AtmosphereSection.astro';
import DefinitionBlock from '../components/DefinitionBlock.astro';
import TestimonialSlider from '../components/TestimonialSlider.astro';
import TeamPreview from '../components/TeamPreview.astro';
import LocationPreview from '../components/LocationPreview.astro';
import GuidesPreview from '../components/GuidesPreview.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTABand from '../components/CTABand.astro';
import { siteConfig } from '../data/site';
import { getReviews, aggregateRating, treatmentLabel, reviewText } from '../data/reviews';
import { generateMedicalBusiness, generateLocalBusiness, generateFAQPage, generateAggregateRating, generateReviewArray } from '../data/schema';

// Image imports — optimised at build time by Astro's <Image> with densities/widths
import heroImg from '../assets/images/hero/hero-clinic.webp';
import spinalDecompressionImg from '../assets/images/treatments/spinal-decompression.webp';
import sportsMassageImg from '../assets/images/treatments/sports-massage.webp';
import posturalAssessmentImg from '../assets/images/treatments/postural-assessment.webp';
import dryNeedlingImg from '../assets/images/treatments/dry-needling.webp';
import atmosphereImg from '../assets/images/atmosphere/costa-blanca.webp';
import treatmentRoomImg from '../assets/images/clinic/treatment-room.webp';
import ctaBgImg from '../assets/images/cta/cta-background.webp';

const services = [
  {
    title: 'Spinal Decompression',
    slug: 'spinal-decompression',
    excerpt: 'Non-surgical treatment to relieve compressed spinal discs, reduce nerve pressure, and restore mobility.',
    icon: 'spine',
    image: spinalDecompressionImg,
    imageAlt: 'Therapist performing manual shoulder and spine therapy on a patient lying on a treatment table',
  },
  {
    title: 'Sports Massage',
    slug: 'sports-massage',
    excerpt: 'Deep tissue and sports-focused massage for faster recovery, injury prevention, and pain relief.',
    icon: 'massage',
    image: sportsMassageImg,
    imageAlt: 'Therapist performing deep tissue massage on a patient shoulder and upper back',
  },
  {
    title: 'Postural Assessment',
    slug: 'postural-assessment',
    excerpt: 'Comprehensive evaluation of your alignment and movement patterns to identify the root cause of pain.',
    icon: 'posture',
    image: posturalAssessmentImg,
    imageAlt: 'Physiotherapist assessing patient spinal posture and alignment in a modern clinic',
  },
  {
    title: 'Dry Needling',
    slug: 'dry-needling',
    excerpt: 'Targeted trigger point therapy using thin needles to release muscle tension and reduce chronic pain.',
    icon: 'needle',
    image: dryNeedlingImg,
    imageAlt: 'Practitioner inserting thin dry needling needles into a patient upper back and neck area',
  },
];

const featuredReviews = getReviews({ featuredOnly: true });
const testimonials = featuredReviews.map((r) => ({
  name: r.name,
  text: reviewText(r, 'en'),
  rating: r.rating,
  source: r.source,
  treatment: treatmentLabel(r.treatmentSlug, 'en'),
  location: r.location,
  date: r.date,
}));
const homepageAggregate = aggregateRating(featuredReviews);

const faqs = [
  {
    q: 'Do I need a referral to visit your clinic?',
    a: 'No, you don\'t need a referral. You can book an appointment directly by phone, WhatsApp, or through our contact form. We welcome both new and returning patients.',
  },
  {
    q: 'Do you treat international patients and expats?',
    a: 'Yes — our clinic primarily serves the international expat community on the Costa Blanca. We speak English, Dutch, and Spanish, and we\'re experienced with international health insurance claims.',
  },
  {
    q: 'What should I expect during my first visit?',
    a: 'Your first visit includes a comprehensive assessment of your condition, medical history, and movement patterns. We\'ll discuss your symptoms, perform a physical examination, and create a personalized treatment plan. Please allow 45–60 minutes.',
  },
  {
    q: 'Is treatment covered by insurance?',
    a: 'Many international health insurance providers cover our treatments. We can provide detailed invoices for reimbursement. Contact us with your insurance details and we\'ll help you understand your coverage.',
  },
];

const trustItems = [
  { value: '15+', label: 'Years\nExperience' },
  { value: '2,300+', label: 'Patients\nTreated' },
  { value: '4.7★', label: 'Google\nRating' },
  { value: '23', label: 'Verified\nReviews' },
];

const approachItems = [
  {
    icon: 'evidence',
    title: 'Evidence-Based Protocols',
    description: 'All treatments follow current clinical evidence and best practice guidelines for proven results.',
  },
  {
    icon: 'multilingual',
    title: 'Multilingual Team',
    description: 'We speak English, Dutch, and Spanish — making healthcare accessible for the expat community.',
  },
  {
    icon: 'nonsurgical',
    title: 'Non-Surgical Techniques',
    description: 'Modern conservative treatments that reduce pain and restore mobility without surgery.',
  },
  {
    icon: 'personalized',
    title: 'Personalised Plans',
    description: 'Every patient receives a tailored treatment plan based on their specific condition and goals.',
  },
];
---

<BaseLayout
  title={`Spine & Mobility Care in Torrevieja | ${siteConfig.shortName}`}
  description="Non-surgical spine and mobility care for the Costa Blanca expat community. Back pain, neck pain, and sports injuries — Torrevieja clinic."
  schemas={[
    generateLocalBusiness(),
    generateMedicalBusiness(),
    generateFAQPage(faqs),
    generateAggregateRating(homepageAggregate),
    ...generateReviewArray(featuredReviews, 'en'),
  ]}
  hreflang={[
    { lang: 'en', href: siteConfig.url },
    { lang: 'nl', href: `${siteConfig.url}/nl` },
  ]}
  locale="en"
>
  <HeroSection
    title="Move Better. Live Better."
    subtitle="Expert spine and mobility care for the expat community on Spain's Costa Blanca. Non-surgical treatments that get you back to the life you love."
    ctaText="Book Appointment"
    ctaHref="/contact"
    secondaryCtaText="Call Us"
    secondaryCtaHref={`tel:${siteConfig.phone}`}
    backgroundImage={heroImg}
    backgroundAlt="Physiotherapist treating a patient on a treatment table in a bright, modern clinic"
    locale="en"
    pageType="homepage"
    pageSlug="/"
  />

  <TrustBar items={trustItems} />

  <ServicesGrid
    title="Our Treatments"
    services={services}
    basePath="/treatments"
    locale="en"
    pageType="homepage"
    pageSlug="/"
  />

  <AtmosphereSection
    image={atmosphereImg}
    quote="Helping you move freely again — in the heart of the Costa Blanca."
    alt="Golden sunset reflecting over calm Mediterranean Sea waters on the Costa Blanca"
  />

  <DefinitionBlock
    term="What We Do"
    definition="Costa Blanca Movement Centre is a specialist mobility and spine health clinic in Torrevieja, Spain. We combine evidence-based manual therapy with modern non-surgical techniques to treat back pain, neck pain, sports injuries, and postural problems. Our multilingual team serves the international expat community across the southern Costa Blanca — from Orihuela Costa to Guardamar del Segura and Pilar de la Horadada."
    image={treatmentRoomImg}
    imageAlt="Physiotherapist providing hands-on treatment to a patient in a warm, modern clinic"
  />

  <ApproachSection
    title="Our Approach"
    items={approachItems}
    locale="en"
  />

  <TestimonialSlider
    testimonials={testimonials}
    locale="en"
  />

  <TeamPreview locale="en" includeSchema={true} />

  <LocationPreview locale="en" />

  <GuidesPreview locale="en" />

  <FAQAccordion
    items={faqs}
    locale="en"
    pageType="homepage"
    pageSlug="/"
    maxItems={4}
    showMoreLink={true}
  />

  <CTABand
    title="Ready to Move Without Pain?"
    subtitle="Book your initial assessment today. We'll create a personalised treatment plan to get you back to doing what you love."
    ctaText="Book Your Assessment"
    ctaHref="/contact"
    backgroundImage={ctaBgImg}
    backgroundAlt="Tranquil Mediterranean beach at sunset with soft purple sky and gentle waves"
    eventName="appointment_click"
    ctaLocation="inline"
    locale="en"
    pageType="homepage"
    pageSlug="/"
  />
</BaseLayout>
