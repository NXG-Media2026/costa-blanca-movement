---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import CTABand from '../../components/CTABand.astro';
import { siteConfig } from '../../data/site';
import { generateLocalBusiness, generateBreadcrumbs } from '../../data/schema';
import { t } from '../../i18n/utils';

const conditions = await getCollection('conditions');
const enConditions = conditions
  .filter((c) => c.data.lang === 'en')
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Conditions' },
];

const schemas = [
  generateLocalBusiness(),
  generateBreadcrumbs([
    { name: 'Home', url: siteConfig.url },
    { name: 'Conditions', url: `${siteConfig.url}/conditions` },
  ]),
];
---

<BaseLayout
  title={`Conditions We Treat | ${siteConfig.shortName}`}
  description="Lower back pain, neck pain, sciatica, herniated discs and more. Learn about your condition and effective non-surgical options."
  canonical={`${siteConfig.url}/conditions`}
  schemas={schemas}
  hreflang={[
    { lang: 'en', href: `${siteConfig.url}/conditions` },
    { lang: 'nl', href: `${siteConfig.url}/nl/klachten` },
  ]}
  locale="en"
>
  <BreadcrumbNav items={breadcrumbs} />

  <section class="py-16 md:py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 md:px-6">
      <div class="max-w-3xl mb-12 md:mb-16">
        <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl text-text mb-6">
          Conditions We Treat
        </h1>
        <p class="text-lg text-text-muted leading-relaxed">
          Understanding your condition is the first step toward recovery. Learn about the symptoms, causes, and effective treatment options for common musculoskeletal conditions.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        {enConditions.map((condition) => (
          <a
            href={`/conditions/${condition.data.pageSlug}`}
            class="group block p-6 md:p-8 bg-white border border-border rounded-card hover:border-accent/30 hover:shadow-lg transition-all duration-300"
          >
            <h2 class="font-heading text-xl md:text-2xl text-text mb-3 group-hover:text-accent transition-colors">
              {condition.data.title}
            </h2>
            <p class="text-text-muted leading-relaxed mb-4">
              {condition.data.definition}
            </p>
            <div class="flex items-center justify-between">
              <span class="text-sm text-text-muted">
                {condition.data.symptoms.length} symptoms
              </span>
              <span class="inline-flex items-center text-sm font-medium text-accent">
                {t('cta.learnMore', 'en')}
                <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABand
    title="Experiencing These Symptoms?"
    subtitle="Don't wait for the pain to get worse. Book an assessment and let us help you find the right treatment."
    ctaText="Book Assessment"
    ctaHref="/contact"
    locale="en"
    pageType="condition"
    pageSlug="conditions"
  />
</BaseLayout>
